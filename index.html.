      toast('Revisão salva localmente (erro Sheets: ' + e.message + ')', 'warning');
    }
  } else {
    toast('Revisão salva (demo)', 'success');
  }

  // Atualizar valor no CRM se aprovada
  if (status === 'Aprovada' && valNovo > 0) {
    const idx = DATA.crm.findIndex(r => parseInt(r[CRM_COL.ID]) === parseInt(idProp));
    if (idx >= 0) {
      DATA.crm[idx][CRM_COL.VALOR] = valNovo.toString();
      if (CONFIG.SHEET_ID && accessToken) {
        try {
          const url = `https://sheets.googleapis.com/v4/spreadsheets/${CONFIG.SHEET_ID}/values/${encodeURIComponent('CRM!H'+(idx+2))}?valueInputOption=USER_ENTERED`;
          await fetch(url, { method:'PUT', headers:{Authorization:'Bearer '+accessToken,'Content-Type':'application/json'}, body:JSON.stringify({values:[[valNovo]]}) });
        } catch(e) {}
      }
      renderDashboardCRM(); renderCRMTable(); renderPipeline();
    }
  }

  closeModal('modal-nova-revisao');
  renderRevisoes();

  // Limpar form
  ['rev-id-prop','rev-cliente','rev-num','rev-val-ant','rev-val-novo','rev-motivo'].forEach(id => {
    const el = document.getElementById(id); if (el) el.value = '';
  });
}

