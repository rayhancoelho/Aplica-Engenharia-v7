/* ═══════════════════════════════════════════
   FASE 3 — TIMER DE HORAS
═══════════════════════════════════════════ */
const TIMER = {
  running:   false,
  paused:    false,
  startTs:   null,   // timestamp quando iniciou/resumiu
  elapsed:   0,      // ms acumulados antes da pausa atual
  interval:  null,
  projeto:   '',
  tipo:      '',
  desc:      '',
};

let TIMER_LOG = JSON.parse(localStorage.getItem('timer_log') || '[]');

function timerPopularProjetos() {
  const sel = document.getElementById('timer-projeto');
  if (!sel) return;
  const cur = sel.value;
  sel.innerHTML = '<option value="">— Sem vínculo —</option>';
  DATA.crm.filter(r => r[CRM_COL.RAZAO] && ['Em prospecção','Enviada','Em Negociação'].includes(r[CRM_COL.STATUS]))
    .forEach((r, i) => {
      const opt = document.createElement('option');
      opt.value = r[0] || i;
      opt.textContent = `#${String(r[0]||i+1).padStart(4,'0')} — ${(r[2]||'').slice(0,30)}`;
      sel.appendChild(opt);
    });
  // Projetos em andamento
  DATA.projetos.filter(r => r[6] === 'Em andamento').forEach(r => {
    const opt = document.createElement('option');
    opt.value = 'PROJ-' + r[0];
    opt.textContent = `🔧 ${r[0]} — ${(r[2]||'').slice(0,28)}`;
    sel.appendChild(opt);
  });
  if (cur) sel.value = cur;
}

function timerStart() {
  if (TIMER.running) return;

  TIMER.projeto = document.getElementById('timer-projeto')?.value || '';
  TIMER.tipo    = document.getElementById('timer-tipo')?.value    || 'Outro';
  TIMER.desc    = document.getElementById('timer-desc')?.value    || '';
  TIMER.running = true;
  TIMER.paused  = false;
  TIMER.startTs = Date.now();

  TIMER.interval = setInterval(timerTick, 500);

  _timerUpdateUI();
  toast('Timer iniciado', 'info');
  const badge = document.getElementById('badge-timer');
  if (badge) badge.style.display = 'inline';
}

function timerPause() {
  if (!TIMER.running || TIMER.paused) return;
  TIMER.elapsed += Date.now() - TIMER.startTs;
  TIMER.paused   = true;
  TIMER.running  = false;
  clearInterval(TIMER.interval);
  _timerUpdateUI();
  toast('Timer pausado', 'warning');
}

function timerResume() {
  if (!TIMER.paused) return;
  TIMER.startTs = Date.now();
  TIMER.running = true;
  TIMER.paused  = false;
  TIMER.interval = setInterval(timerTick, 500);
  _timerUpdateUI();
}

async function timerStop() {
  if (!TIMER.running && !TIMER.paused) return;

  if (TIMER.running) {
    TIMER.elapsed += Date.now() - TIMER.startTs;
  }
  clearInterval(TIMER.interval);

  const duracaoMs  = TIMER.elapsed;
  const duracaoH   = duracaoMs / 3600000;

  if (duracaoH < 0.01) {
    toast('Duração muito curta, cancelando', 'warning');
    _timerReset();
    return;
  }

  const entrada = {
    id:      Date.now(),
    data:    new Date().toLocaleDateString('pt-BR'),
    hora_ini: new Date(Date.now() - duracaoMs).toLocaleTimeString('pt-BR', {hour:'2-digit',minute:'2-digit'}),
    hora_fim: new Date().toLocaleTimeString('pt-BR', {hour:'2-digit',minute:'2-digit'}),
    duracao_ms: duracaoMs,
    duracao_h:  parseFloat(duracaoH.toFixed(2)),
    projeto:  TIMER.projeto,
    tipo:     TIMER.tipo,
    desc:     TIMER.desc,
  };

  TIMER_LOG.push(entrada);
  _timerSalvarLocal();
  _timerReset();
  timerRenderLog();
  renderDashTempo();
  toast(`✅ ${_fmtDuracao(duracaoMs)} registradas — ${entrada.tipo}`, 'success');
}

function timerRegistrarManual() {
  const data  = document.getElementById('timer-man-data')?.value  || '';
  const horas = parseFloat(document.getElementById('timer-man-horas')?.value || '0') || 0;

  if (!horas || horas <= 0) { toast('Informe a duração em horas', 'warning'); return; }

  const projeto = document.getElementById('timer-projeto')?.value || '';
  const tipo    = document.getElementById('timer-tipo')?.value    || 'Outro';
  const desc    = document.getElementById('timer-desc')?.value    || '';

  const entrada = {
    id:         Date.now(),
    data:       data ? new Date(data + 'T12:00:00').toLocaleDateString('pt-BR') : new Date().toLocaleDateString('pt-BR'),
    hora_ini:   '—',
    hora_fim:   '—',
    duracao_ms: horas * 3600000,
    duracao_h:  horas,
    projeto,
    tipo,
    desc,
  };

  TIMER_LOG.push(entrada);
  _timerSalvarLocal();
  timerRenderLog();
  renderDashTempo();

  document.getElementById('timer-man-horas').value = '';
  document.getElementById('timer-man-data').value  = '';
  toast(`+ ${horas}h registradas manualmente`, 'success');
}

function timerTick() {
  const total = TIMER.elapsed + (Date.now() - TIMER.startTs);
  const el = document.getElementById('timer-display');
  if (el) el.textContent = _fmtDuracao(total);
}

function _fmtDuracao(ms) {
  const s   = Math.floor(ms / 1000);
  const h   = Math.floor(s / 3600);
  const min = Math.floor((s % 3600) / 60);
  const sec = s % 60;
  return `${String(h).padStart(2,'0')}:${String(min).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
}

function _fmtH(h) {
  const hrs = Math.floor(h);
  const min = Math.round((h - hrs) * 60);
  if (hrs === 0) return `${min}min`;
  if (min === 0) return `${hrs}h`;
  return `${hrs}h ${min}min`;
}

function _timerUpdateUI() {
  const display  = document.getElementById('timer-display');
  const btnStart = document.getElementById('btn-timer-start');
  const btnPause = document.getElementById('btn-timer-pause');
  const btnStop  = document.getElementById('btn-timer-stop');
  const label    = document.getElementById('timer-status-label');

  if (TIMER.running) {
    if (display) display.className = 'timer-display running';
    if (btnStart) btnStart.style.display = 'none';
    if (btnPause) { btnPause.style.display = ''; btnPause.textContent = '⏸ Pausar'; btnPause.onclick = timerPause; }
    if (btnStop)  btnStop.style.display = '';
    if (label)    label.textContent = '● Rodando';
  } else if (TIMER.paused) {
    if (display) display.className = 'timer-display paused';
    if (btnStart) btnStart.style.display = 'none';
    if (btnPause) { btnPause.style.display = ''; btnPause.textContent = '▶ Retomar'; btnPause.onclick = timerResume; }
    if (btnStop)  btnStop.style.display = '';
    if (label)    label.textContent = '⏸ Pausado';
  } else {
    if (display) { display.className = 'timer-display'; display.textContent = '00:00:00'; }
    if (btnStart) btnStart.style.display = '';
    if (btnPause) btnPause.style.display = 'none';
    if (btnStop)  btnStop.style.display  = 'none';
    if (label)    label.textContent = 'Parado';
    const badge = document.getElementById('badge-timer');
    if (badge) badge.style.display = 'none';
  }
}

function _timerReset() {
  TIMER.running  = false;
  TIMER.paused   = false;
  TIMER.elapsed  = 0;
  TIMER.startTs  = null;
  TIMER.projeto  = '';
  clearInterval(TIMER.interval);
  _timerUpdateUI();
}

function _timerSalvarLocal() {
  try { localStorage.setItem('timer_log', JSON.stringify(TIMER_LOG.slice(-500))); } catch(e) {}
}

function timerRenderLog() {
  const hoje = new Date().toLocaleDateString('pt-BR');

  // Log de hoje
  const hoje_entries = TIMER_LOG.filter(e => e.data === hoje);
  const hoje_total_h = hoje_entries.reduce((s, e) => s + (e.duracao_h || 0), 0);

  const logHoje = document.getElementById('timer-log-hoje');
  if (logHoje) {
    if (!hoje_entries.length) {
      logHoje.innerHTML = `<div class="empty-state" style="padding:20px"><div class="empty-icon" style="font-size:22px">⏱️</div><div class="empty-sub">Nenhum registro hoje</div></div>`;
    } else {
      logHoje.innerHTML = hoje_entries.slice().reverse().map(e => `
        <div class="timer-log-item">
          <span class="timer-log-dur">${_fmtH(e.duracao_h)}</span>
          <div style="flex:1;min-width:0">
            <div class="timer-log-proj">${e.tipo}</div>
            <div class="timer-log-desc">${e.projeto ? '📌 ' + e.projeto : ''}${e.desc ? ' · ' + e.desc : ''}</div>
          </div>
          <span class="timer-log-date">${e.hora_ini}–${e.hora_fim}</span>
          <button style="background:none;border:none;color:var(--coral);cursor:pointer;font-size:13px;padding:0 4px" onclick="timerRemover(${e.id})">×</button>
        </div>`).join('');
    }
  }

  const totalEl = document.getElementById('timer-hoje-total');
  if (totalEl) totalEl.textContent = _fmtH(hoje_total_h);

  // Log completo (últimos 100)
  const logFull = document.getElementById('timer-log-full');
  if (logFull) {
    if (!TIMER_LOG.length) {
      logFull.innerHTML = `<div class="empty-state" style="padding:16px"><div class="empty-icon" style="font-size:20px">📋</div><div class="empty-sub">Sem registros</div></div>`;
    } else {
      logFull.innerHTML = TIMER_LOG.slice().reverse().slice(0, 100).map(e => `
        <div class="timer-log-item">
          <span class="timer-log-dur">${_fmtH(e.duracao_h)}</span>
          <div style="flex:1;min-width:0">
            <div class="timer-log-proj">${e.tipo}</div>
            <div class="timer-log-desc">${e.projeto ? '📌 #' + e.projeto + ' · ' : ''}${e.desc || ''}</div>
          </div>
          <span class="timer-log-date">${e.data}</span>
          <button style="background:none;border:none;color:var(--coral);cursor:pointer;font-size:13px;padding:0 4px" onclick="timerRemover(${e.id})">×</button>
        </div>`).join('');
    }
  }

  // Semana
  _timerRenderSemana();
}

function timerRemover(id) {
  TIMER_LOG = TIMER_LOG.filter(e => e.id !== id);
  _timerSalvarLocal();
  timerRenderLog();
  renderDashTempo();
}

function _timerRenderSemana() {
  const hoje  = new Date(); hoje.setHours(0,0,0,0);

  // Últimas 4 semanas = 28 dias
  const dias = [];
  for (let i = 27; i >= 0; i--) {
    const d = new Date(hoje);
    d.setDate(d.getDate() - i);
    dias.push(d);
  }

  // Horas por dia
  const hPorDia = {};
  TIMER_LOG.forEach(e => {
    const d = parseDate(e.data);
    if (!d) return;
    const key = d.toLocaleDateString('pt-BR');
    hPorDia[key] = (hPorDia[key] || 0) + (e.duracao_h || 0);
  });

  const maxH = Math.max(...Object.values(hPorDia), 1);

  // Heatmap labels (Seg-Dom)
  const labelsEl = document.getElementById('heatmap-labels');
  if (labelsEl) {
    labelsEl.innerHTML = ['Seg','Ter','Qua','Qui','Sex','Sáb','Dom']
      .map(d => `<div class="heatmap-label">${d}</div>`).join('');
  }

  // Grid (28 células, começando na segunda da semana inicial)
  // Ajustar para começar no dia correto
  const primeiroDia = dias[0];
  const diaSemana   = primeiroDia.getDay(); // 0=Dom
  const offset      = diaSemana === 0 ? 6 : diaSemana - 1; // offset para segunda

  const gridEl = document.getElementById('heatmap-grid');
  if (!gridEl) return;

  // Padding inicial
  let cells = '';
  for (let p = 0; p < offset; p++) {
    cells += `<div class="heatmap-cell h0"></div>`;
  }

  dias.forEach(d => {
    const key = d.toLocaleDateString('pt-BR');
    const h   = hPorDia[key] || 0;
    const isToday = d.getTime() === hoje.getTime();
    let cls = 'h0';
    if (h > 0) {
      const pct = h / maxH;
      if (pct < 0.25)      cls = 'h1';
      else if (pct < 0.5)  cls = 'h2';
      else if (pct < 0.75) cls = 'h3';
      else                 cls = 'h4';
    }
    cells += `<div class="heatmap-cell ${cls}${isToday?' today':''}" title="${key}: ${_fmtH(h)}">${d.getDate()}</div>`;
  });

  gridEl.innerHTML = cells;

  // Stats semana atual (últimos 7 dias)
  const em7d = dias.slice(-7);
  let semH  = 0, semDias = 0;
  em7d.forEach(d => {
    const h = hPorDia[d.toLocaleDateString('pt-BR')] || 0;
    semH  += h;
    if (h > 0) semDias++;
  });

  const el1 = document.getElementById('tw-horas');
  const el2 = document.getElementById('tw-dias');
  const el3 = document.getElementById('tw-media');
  if (el1) el1.textContent = _fmtH(semH);
  if (el2) el2.textContent = semDias;
  if (el3) el3.textContent = semDias > 0 ? _fmtH(semH / semDias) : '0h';
}

async function timerExportarSheets() {
  if (!TIMER_LOG.length) { toast('Sem registros para exportar', 'warning'); return; }
  if (!CONFIG.SHEET_ID || !accessToken) {
    toast('Configure o Sheets e faça login para exportar', 'warning'); return;
  }

  try {
    toast('Exportando para o Sheets...', 'info');
    const rows = TIMER_LOG.slice(-200).map(e => [
      e.data, e.hora_ini, e.hora_fim, e.duracao_h, e.projeto, e.tipo, e.desc
    ]);
    await sheetsAppend('TIMER', rows);
    toast(`✅ ${rows.length} registros exportados para a aba TIMER`, 'success');
  } catch(e) {
    toast('Erro: ' + e.message, 'error');
  }
}

/* ═══════════════════════════════════════════
   FASE 3.2 — DASHBOARD TEMPO
═══════════════════════════════════════════ */
let chartTipoAtiv = null;
let chartHorasDia = null;

function renderDashTempo() {
  const dias  = parseInt(document.getElementById('dt-period')?.value || '30') || 30;
  const corte = dias > 0 ? new Date(Date.now() - dias * 86400000) : null;

  const logs  = corte
    ? TIMER_LOG.filter(e => { const d = parseDate(e.data); return d && d >= corte; })
    : TIMER_LOG;

  const mesAtual = new Date().getMonth();
  const anoAtual = new Date().getFullYear();
  const logsMes  = TIMER_LOG.filter(e => {
    const d = parseDate(e.data);
    return d && d.getMonth() === mesAtual && d.getFullYear() === anoAtual;
  });
  const horasMes = logsMes.reduce((s, e) => s + (e.duracao_h || 0), 0);

  // KPIs
  const projAtivos = [...new Set(logs.filter(e => e.projeto).map(e => e.projeto))].length;
  const tipoCount  = {};
  logs.forEach(e => { tipoCount[e.tipo || 'Outro'] = (tipoCount[e.tipo||'Outro']||0) + (e.duracao_h||0); });
  const topTipo    = Object.entries(tipoCount).sort((a,b) => b[1]-a[1])[0]?.[0] || '—';

  // R$/hora
  const recMes = DATA.financeiro.reduce((s, r) => {
    const d = parseDate(r[9]||r[0]);
    if (d && d.getMonth() === mesAtual && d.getFullYear() === anoAtual) {
      return s + (parseFloat((r[3]||'0').toString().replace(',','.')) || 0);
    }
    return s;
  }, 0);
  const rph = horasMes > 0 ? (recMes / horasMes) : 0;

  set('dt-horas-mes', _fmtH(horasMes));
  set('dt-rph',       rph > 0 ? fmtMoney(rph) : '—');
  set('dt-proj-ativos', projAtivos);
  set('dt-top-ativ',  topTipo.length > 16 ? topTipo.slice(0,14)+'…' : topTipo);
  ['dt-horas-mes','dt-rph','dt-proj-ativos','dt-top-ativ'].forEach(id => document.getElementById(id)?.classList.remove('loading-val'));

  // Barras por projeto
  const hPorProj = {};
  logs.forEach(e => {
    const k = e.projeto || '(Sem projeto)';
    hPorProj[k] = (hPorProj[k] || 0) + (e.duracao_h || 0);
  });
  const sortedProj = Object.entries(hPorProj).sort((a,b) => b[1]-a[1]).slice(0, 10);
  const maxProjH   = sortedProj[0]?.[1] || 1;

  const projBars = document.getElementById('dt-proj-bars');
  if (projBars) {
    if (!sortedProj.length) {
      projBars.innerHTML = `<div class="empty-state"><div class="empty-icon">📊</div><div class="empty-sub">Sem dados no período</div></div>`;
    } else {
      projBars.innerHTML = sortedProj.map(([nome, h]) => `
        <div class="proj-bar-row">
          <div class="proj-bar-header">
            <span class="proj-bar-name">${nome.length > 32 ? nome.slice(0,30)+'…' : nome}</span>
            <span class="proj-bar-val">${_fmtH(h)}</span>
          </div>
          <div class="proj-bar-track">
            <div class="proj-bar-fill" style="width:${(h/maxProjH*100).toFixed(1)}%"></div>
          </div>
        </div>`).join('');
    }
  }

  // Produtividade R$/hora por projeto
  const rphProj = document.getElementById('dt-rph-proj');
  if (rphProj) {
    const projComValor = sortedProj.map(([nome, h]) => {
      // Tentar encontrar valor da proposta
      const crmRow = DATA.crm.find(r => String(r[0]) === nome || r[2] === nome);
      const valor  = crmRow ? parseFloat((crmRow[7]||'0').toString().replace(',','.')) || 0 : 0;
      return { nome, h, valor, rph: h > 0 && valor > 0 ? valor/h : 0 };
    }).filter(p => p.rph > 0).sort((a,b) => b.rph - a.rph);

    if (!projComValor.length) {
      rphProj.innerHTML = `<div class="empty-state"><div class="empty-icon">💰</div><div class="empty-sub">Vincule projetos do CRM ao timer para calcular produtividade</div></div>`;
    } else {
      const maxRph = projComValor[0].rph;
      rphProj.innerHTML = projComValor.map(p => `
        <div class="proj-bar-row">
          <div class="proj-bar-header">
            <span class="proj-bar-name">${p.nome.length > 28 ? p.nome.slice(0,26)+'…' : p.nome}</span>
            <span class="proj-bar-val" style="color:var(--gold)">${fmtMoney(p.rph)}/h</span>
          </div>
          <div class="proj-bar-track">
            <div class="proj-bar-fill" style="width:${(p.rph/maxRph*100).toFixed(1)}%;background:var(--gold)"></div>
          </div>
        </div>`).join('');
    }
  }

  // Gráfico por tipo de atividade (doughnut)
  const tiposLabel  = Object.keys(tipoCount);
  const tiposVals   = tiposLabel.map(k => tipoCount[k]);
  const tiposCores  = ['#4493f8','#f0a500','#2ec4a0','#bc8cff','#3fb950','#f85149','#8b949e','#e05c00'];

  const ctx1 = document.getElementById('chartTipoAtiv');
  if (ctx1) {
    if (chartTipoAtiv) chartTipoAtiv.destroy();
    chartTipoAtiv = new Chart(ctx1, {
      type: 'doughnut',
      data: {
        labels: tiposLabel,
        datasets: [{ data: tiposVals, backgroundColor: tiposCores.slice(0, tiposLabel.length), borderWidth: 0, hoverOffset: 6 }]
      },
      options: { cutout: '68%', plugins: { legend: { display: false } } }
    });

    const leg = document.getElementById('dt-ativ-legend');
    if (leg) {
      leg.innerHTML = tiposLabel.map((l, i) => `
        <div style="display:flex;align-items:center;gap:7px">
          <div style="width:8px;height:8px;border-radius:2px;background:${tiposCores[i]||'#8b949e'};flex-shrink:0"></div>
          <span style="color:var(--text2);font-size:11px">${l}</span>
          <span style="margin-left:auto;color:var(--steel);font-family:monospace;font-size:11px">${_fmtH(tiposVals[i])}</span>
        </div>`).join('');
    }
  }

  // Gráfico horas por dia da semana (bar)
  const diasSemana = ['Seg','Ter','Qua','Qui','Sex','Sáb','Dom'];
  const hPorDiaSem = Array(7).fill(0);
  logs.forEach(e => {
    const d = parseDate(e.data);
    if (!d) return;
    const dow = d.getDay(); // 0=Dom
    const idx = dow === 0 ? 6 : dow - 1;
    hPorDiaSem[idx] += e.duracao_h || 0;
  });

  const ctx2 = document.getElementById('chartHorasDia');
  if (ctx2) {
    if (chartHorasDia) chartHorasDia.destroy();
    chartHorasDia = new Chart(ctx2, {
      type: 'bar',
      data: {
        labels: diasSemana,
        datasets: [{
          data: hPorDiaSem,
          backgroundColor: hPorDiaSem.map((v, i) => i < 5 ? 'rgba(68,147,248,0.7)' : 'rgba(72,79,88,0.5)'),
          borderRadius: 5,
          borderSkipped: false,
          hoverBackgroundColor: '#f0a500',
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { display: false },
          tooltip: { callbacks: { label: ctx => _fmtH(ctx.parsed.y) } }
        },
        scales: {
          x: { grid: { color: '#21262d' }, ticks: { color: '#8b949e', font: { size: 11 } } },
          y: { grid: { color: '#21262d' }, ticks: { color: '#8b949e', font: { size: 11 }, callback: v => v + 'h' } }
        }
      }
    });
  }
}

