let chartFat = null;
let chartServ = null;
let chartDesp = null;

function initFinCharts() {
  // Faturamento mensal — calcular dos dados reais
  const meses = ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
  const anoAtual = new Date().getFullYear();
  const fatPorMes = Array(12).fill(0);
  const projPorMes = Array(12).fill(0);

  DATA.financeiro.forEach(r => {
    const data = r[9] || r[0] || '';
    const d = parseDate(data);
    if (d && d.getFullYear() === anoAtual) {
      const m = d.getMonth();
      const val = parseFloat((r[3]||'0').toString().replace(',','.')) || 0;
      fatPorMes[m] += val;
      projPorMes[m]++;
    }
  });

  const mesAtual = new Date().getMonth();
  const recMes = fatPorMes[mesAtual];
  const recAnt = fatPorMes[mesAtual > 0 ? mesAtual-1 : 11] || 1;
  const varPct  = ((recMes - recAnt)/recAnt*100).toFixed(1);

  set('kpi-rec-mes', fmtMoney(recMes));
  set('kpi-rec-delta', (varPct >= 0 ? '▲ ':'▼ ') + Math.abs(varPct) + '% vs mês anterior');
  ['kpi-rec-mes'].forEach(id => document.getElementById(id)?.classList.remove('loading-val'));

  // Despesas
  let despMes = 0;
  DATA.despesas.forEach(r => {
    const d = parseDate(r[0]);
    if (d && d.getMonth() === mesAtual && d.getFullYear() === anoAtual) {
      despMes += parseFloat((r[3]||'0').toString().replace(',','.')) || 0;
    }
  });

  set('kpi-desp-mes', fmtMoney(despMes));
  set('kpi-resultado', fmtMoney(recMes - despMes));
  set('kpi-nfs', projPorMes[mesAtual]);
  ['kpi-desp-mes','kpi-resultado','kpi-nfs'].forEach(id => document.getElementById(id)?.classList.remove('loading-val'));

  // Tabela faturamento
  const fatRows = meses.map((m, i) => {
    const var_m = i > 0 && fatPorMes[i-1] > 0
      ? ((fatPorMes[i]-fatPorMes[i-1])/fatPorMes[i-1]*100).toFixed(1)
      : null;
    return `<tr ${i === mesAtual ? 'style="background:rgba(46,196,160,0.05)"' : ''}>
      <td class="fw-bold">${m}/${anoAtual.toString().slice(2)}</td>
      <td class="text-teal font-mono fw-bold">${fmtMoney(fatPorMes[i])}</td>
      <td>${projPorMes[i]}</td>
      <td class="text-muted">${projPorMes[i] > 0 ? fmtMoney(fatPorMes[i]/projPorMes[i]) : '—'}</td>
      <td class="${var_m !== null ? (parseFloat(var_m) >= 0 ? 'text-green':'text-coral') : 'text-dim'}">${var_m !== null ? (parseFloat(var_m) >= 0 ? '▲ ':'▼ ') + Math.abs(var_m) + '%' : '—'}</td>
    </tr>`;
  });
  document.getElementById('fat-table-body').innerHTML = fatRows.join('');

  // Gráfico faturamento
  const ctx1 = document.getElementById('chartFaturamento');
  if (!ctx1) return;

  if (chartFat) chartFat.destroy();
  chartFat = new Chart(ctx1, {
    type: 'bar',
    data: {
      labels: meses,
      datasets: [{
        data: fatPorMes,
        backgroundColor: ctx => ctx.parsed.y > 0 ? 'rgba(46,196,160,0.8)' : '#21262d',
        borderRadius: 5,
        borderSkipped: false,
        hoverBackgroundColor: '#f0a500'
      }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { display: false },
        tooltip: { callbacks: { label: ctx => 'R$ ' + ctx.parsed.y.toLocaleString('pt-BR') } }
      },
      scales: {
        x: { grid: { color: '#21262d' }, ticks: { color: '#8b949e', font: { size: 11 } } },
        y: { grid: { color: '#21262d' }, ticks: { color: '#8b949e', font: { size: 11 }, callback: v => 'R$' + (v/1000).toFixed(0) + 'k' } }
      }
    }
  });

  // Gráfico por serviço
  const servNomes = ['Aterramento','SPDA','Laudo','Proj.Elét.','Medição','Iluminação','Alarme'];
  const servKeys  = ['ATERRAMENTO','SPDA','LAUDO','PROJETO','MEDI','ILUMINA','ALARME'];
  const servCores = ['#f0a500','#3fb950','#4493f8','#bc8cff','#2ec4a0','#f85149','#8b949e'];
  const servVals  = servKeys.map(k =>
    DATA.financeiro.reduce((acc, r) => acc + ((r[4]||'').toUpperCase().includes(k) ? (parseFloat((r[3]||'0').replace(',','.')) || 0) : 0), 0)
  );

  const ctx2 = document.getElementById('chartServicos');
  if (chartServ) chartServ.destroy();
  chartServ = new Chart(ctx2, {
    type: 'doughnut',
    data: {
      labels: servNomes,
      datasets: [{ data: servVals, backgroundColor: servCores, borderWidth: 0, hoverOffset: 6 }]
    },
    options: {
      cutout: '70%',
      plugins: { legend: { display: false } }
    }
  });

  // Legend
  const leg = document.getElementById('chart-legend');
  if (leg) {
    leg.innerHTML = servNomes.map((n,i) => servVals[i] > 0 ? `
      <div style="display:flex;align-items:center;gap:8px">
        <div style="width:8px;height:8px;border-radius:2px;background:${servCores[i]};flex-shrink:0"></div>
        <span style="color:var(--text2)">${n}</span>
        <span style="margin-left:auto;color:var(--teal);font-family:monospace">${fmtMoney(servVals[i])}</span>
      </div>` : '').join('');
  }
}

