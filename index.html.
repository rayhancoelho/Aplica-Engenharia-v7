// ── DASHBOARD CRM
function renderDashboardCRM() {
  const rows = DATA.crm;
  const total = rows.length;

  // Cols CRM via CRM_COL (0-indexed)
  const STATUS_COL = CRM_COL.STATUS;
  const VALOR_COL  = CRM_COL.VALOR;
  const VALID_COL  = CRM_COL.VALIDADE;
  const FOLLOW_COL = CRM_COL.FOLLOWUP;
  const RET_COL    = CRM_COL.RETORNO;

  const statusCount = {};
  const statusVal   = {};
  let totalAberto = 0;
  let totalGanhas = 0;
  let recPotencial = 0;

  const hoje = new Date(); hoje.setHours(0,0,0,0);
  const em7d = new Date(hoje); em7d.setDate(em7d.getDate() + 7);

  let vencendo = [];
  let followups = [];

  rows.forEach(r => {
    const status = r[STATUS_COL] || '—';
    const val    = parseFloat((r[VALOR_COL] || '0').toString().replace(',','.')) || 0;

    statusCount[status] = (statusCount[status] || 0) + 1;
    statusVal[status]   = (statusVal[status]   || 0) + val;

    if (['Em prospecção','Enviada','Em Negociação'].includes(status)) {
      totalAberto++;
      recPotencial += val;
    }
    if (status === 'Ganha') totalGanhas++;

    // Vencendo
    const vd = parseDate(r[VALID_COL]);
    if (vd && vd >= hoje && vd <= em7d && ['Em prospecção','Enviada','Em Negociação'].includes(status)) {
      vencendo.push({ cliente: r[CRM_COL.RAZAO] || '—', cnpj: r[CRM_COL.CNPJ] || '—', vence: r[VALID_COL], valor: val });
    }

    // Follow-ups
    const fd = parseDate(r[FOLLOW_COL]);
    if (fd && fd >= hoje && fd <= em7d) {
      followups.push({ cliente: r[CRM_COL.RAZAO] || '—', cnpj: r[CRM_COL.CNPJ] || '—', followup: r[CRM_COL.FOLLOWUP], canal: r[CRM_COL.CANAL] || '—' });
    }
  });

  const conv = total > 0 ? (totalGanhas / total * 100).toFixed(1) + '%' : '0%';

  // KPIs
  set('kpi-total',  total);
  set('kpi-aberto', totalAberto);
  set('kpi-conv',   conv);
  set('kpi-pot',    fmtMoney(recPotencial));
  set('kpi-follow', followups.length);
  ['kpi-total','kpi-aberto','kpi-conv','kpi-pot','kpi-follow'].forEach(id => {
    document.getElementById(id)?.classList.remove('loading-val');
  });

  // Status table
  const statusOrder = ['Em prospecção','Enviada','Em Negociação','Ganha','Perdida','Expirada'];
  const statusColors = {
    'Em prospecção': 'badge-steel', 'Enviada': 'badge-gold',
    'Em Negociação': 'badge-lavender', 'Ganha': 'badge-green',
    'Perdida': 'badge-coral', 'Expirada': 'badge-dim'
  };

  document.getElementById('status-table-body').innerHTML = statusOrder
    .filter(s => statusCount[s])
    .map(s => `<tr>
      <td><span class="badge ${statusColors[s]||'badge-dim'}">${s}</span></td>
      <td class="fw-bold">${statusCount[s]||0}</td>
      <td class="text-dim">${total > 0 ? ((statusCount[s]||0)/total*100).toFixed(0)+'%' : '0%'}</td>
      <td class="text-teal font-mono">${fmtMoney(statusVal[s]||0)}</td>
    </tr>`).join('') || '<tr><td colspan="4" class="text-dim" style="text-align:center;padding:20px">Sem dados</td></tr>';

  // Vencendo
  const vDiv = document.getElementById('vencendo-list');
  if (vencendo.length === 0) {
    vDiv.innerHTML = `<div class="empty-state"><div class="empty-icon">✅</div><div class="empty-title">Tudo em dia</div><div class="empty-sub">Nenhuma proposta vencendo nos próximos 7 dias.</div></div>`;
  } else {
    vDiv.innerHTML = vencendo.map(v => `
      <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 12px;border-bottom:1px solid var(--border);font-size:12px">
        <div>
          <div class="fw-bold">${v.cliente}</div>
          <div class="text-dim">${v.cnpj}</div>
        </div>
        <div style="text-align:right">
          <div class="text-coral fw-bold">${v.vence}</div>
          <div class="text-teal font-mono">${fmtMoney(v.valor)}</div>
        </div>
      </div>`).join('');
  }

  // Por serviço
  const servicos = ['ATERRAMENTO ELÉTRICO','SPDA - SISTEMA DE PROTEÇÃO','LAUDO TÉCNICO','PROJETO ELÉTRICO','MEDIÇÃO E VERIFICAÇÃO','ILUMINAÇÃO - LUMINOTÉCNICA','SISTEMA DE ALARME'];
  const SERV_COL = 3;
  const shortNames = { 'ATERRAMENTO ELÉTRICO':'Aterramento', 'SPDA - SISTEMA DE PROTEÇÃO':'SPDA', 'LAUDO TÉCNICO':'Laudo Técnico', 'PROJETO ELÉTRICO':'Proj. Elétrico', 'MEDIÇÃO E VERIFICAÇÃO':'Medição', 'ILUMINAÇÃO - LUMINOTÉCNICA':'Iluminação', 'SISTEMA DE ALARME':'Sis. Alarme' };

  document.getElementById('servico-table-body').innerHTML = servicos.map(sv => {
    const enviadas = rows.filter(r => (r[SERV_COL]||'').toUpperCase().includes(sv.split(' ')[0])).length;
    const ganhas   = rows.filter(r => (r[SERV_COL]||'').toUpperCase().includes(sv.split(' ')[0]) && r[STATUS_COL]==='Ganha').length;
    const conv_s   = enviadas > 0 ? (ganhas/enviadas*100).toFixed(0)+'%' : '—';
    return `<tr>
      <td class="fw-bold">${shortNames[sv]||sv}</td>
      <td>${enviadas}</td>
      <td class="text-green">${ganhas}</td>
      <td class="text-dim">${conv_s}</td>
    </tr>`;
  }).join('');

  // Retorno clientes (col AC = 28)
  const retornos = ['Respondeu','Não Respondeu','Pediu prazo','Sem Contato'];
  const retColors = { 'Respondeu':'badge-green','Não Respondeu':'badge-coral','Pediu prazo':'badge-gold','Sem Contato':'badge-dim' };
  const retCount = {};
  rows.forEach(r => {
    const ret = r[RET_COL] || '';
    if (ret) retCount[ret] = (retCount[ret]||0) + 1;
  });

  document.getElementById('retorno-table-body').innerHTML = retornos
    .filter(r => retCount[r])
    .map(r => `<tr>
      <td><span class="badge ${retColors[r]||'badge-dim'}">${r}</span></td>
      <td>${retCount[r]||0}</td>
      <td class="text-dim">${total > 0 ? ((retCount[r]||0)/total*100).toFixed(0)+'%':'—'}</td>
    </tr>`).join('') || '<tr><td colspan="3" class="text-dim" style="text-align:center;padding:16px">Sem dados</td></tr>';
}

