async function saveDetalhe(idx) {
  toast('Salvando...', 'info');
  const obs = document.getElementById('det-reg')?.value || '';
  if (DATA.crm[idx]) DATA.crm[idx][CRM_COL.OBS] = obs;
  closeModal('modal-detalhe');
  toast('Salvo localmente (sincronize para persistir)', 'success');
}

async function updateStatus(idx, novoStatus) {
  const statusAntes = DATA.crm[idx]?.[CRM_COL.STATUS];

  if (!CONFIG.SHEET_ID) {
    if (DATA.crm[idx]) DATA.crm[idx][CRM_COL.STATUS] = novoStatus;
    renderDashboardCRM();
    renderCRMTable();
    if (novoStatus === 'Ganha' && statusAntes !== 'Ganha') await transferirParaFinanceiro(DATA.crm[idx]);
    toast('Status atualizado (demo)', 'success');
    closeModal('modal-detalhe');
    return;
  }

  try {
    const rowReal = idx + 2;
    const range = `${CONFIG.SHEETS.CRM}!M${rowReal}`;
    const url   = `https://sheets.googleapis.com/v4/spreadsheets/${CONFIG.SHEET_ID}/values/${encodeURIComponent(range)}?valueInputOption=USER_ENTERED`;
    await fetch(url, {
      method: 'PUT',
      headers: { Authorization: 'Bearer ' + accessToken, 'Content-Type': 'application/json' },
      body: JSON.stringify({ values: [[novoStatus]] })
    });
    if (DATA.crm[idx]) DATA.crm[idx][CRM_COL.STATUS] = novoStatus;
    renderDashboardCRM();
    renderCRMTable();
    if (novoStatus === 'Ganha' && statusAntes !== 'Ganha') await transferirParaFinanceiro(DATA.crm[idx]);
    closeModal('modal-detalhe');
    toast('Status atualizado para: ' + novoStatus, 'success');
  } catch(e) {
    toast('Erro ao atualizar: ' + e.message, 'error');
  }
}

