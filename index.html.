// ── LANÇAR DESPESA ────────────────────────
function renderDespesasTable(filtroQ = '', filtroCat = '') {
  const tbody = document.getElementById('desp-table-body');
  if (!tbody) return;

  const rows = DATA.despesas.filter(r => {
    const q    = filtroQ.toLowerCase();
    const ok1  = !q       || [r[1],r[2]].some(v => (v||'').toLowerCase().includes(q));
    const ok2  = !filtroCat || (r[2]||'').toLowerCase().includes(filtroCat.toLowerCase());
    return ok1 && ok2;
  });

  if (!rows.length) {
    tbody.innerHTML = `<tr><td colspan="6"><div class="empty-state" style="padding:24px"><div class="empty-icon">📤</div><div class="empty-title">Sem despesas</div><div class="empty-sub">Lance sua primeira despesa</div></div></td></tr>`;
    return;
  }

  tbody.innerHTML = rows.map((r, i) => `
    <tr>
      <td class="text-dim">${r[0]||'—'}</td>
      <td style="font-weight:500">${(r[1]||'—').slice(0,32)}</td>
      <td><span class="badge badge-dim" style="font-size:10px">${r[2]||'—'}</span></td>
      <td class="text-coral font-mono fw-bold">${fmtMoney(f4GetDespValor(r))}</td>
