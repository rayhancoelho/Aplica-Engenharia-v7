<script>
/* ═══════════════════════════════════════════
   CONFIG & STATE
═══════════════════════════════════════════ */
const CONFIG = {
  // Preencher em Configurações ou hardcode aqui:
  SHEET_ID:    localStorage.getItem('sheet_id')    || '',
  CLIENT_ID:   localStorage.getItem('client_id')   || '',
  CALENDAR_ID: localStorage.getItem('cal_id')      || 'primary',

  // Escopos necessários
  SCOPES: [
    'https://www.googleapis.com/auth/spreadsheets',
    'https://www.googleapis.com/auth/calendar',
    'https://www.googleapis.com/auth/userinfo.profile',
    'https://www.googleapis.com/auth/userinfo.email'
  ].join(' '),

  // Abas da planilha (nomes exatos)
  SHEETS: {
    CRM:                 'CRM',
    FINANCEIRO:          'FINANCEIRO',
    CLIENTES:            'CLIENTES',
    PROJETOS:            'PROJETOS',
    DESPESAS:            'DESPESAS',
    MARKETING:           'MARKETING',
    LISTAS:              'LISTAS',
    HISTORICO_PROPOSTAS: 'HISTORICO_PROPOSTAS',
    HISTORICO_NF:        'HISTORICO_NF',
    TIMER:               'TIMER',
    CADASTRO:            'CADASTRO',
  }
};

// ── Mapeamento de colunas CRM (0-indexed, baseado na planilha v28) ──
// A=0  B=1  C=2  D=3  E=4  F=5  G=6  H=7  I=8  J=9  K=10  L=11  M=12
// N=13 O=14 P=15 Q=16 R=17 S=18 T=19 U=20 V=21 W=22 X=23  Y=24  Z=25
// AA=26 AB=27 AC=28 AD=29 AE=30 AF=31 AG=32 AH=33 AI=34 AJ=35 AK=36 AL=37 AM=38 AN=39 AO=40 AP=41 AQ=42 AR=43
const CRM_COL = {
  ID:        0,
  CNPJ:      1,
  RAZAO:     2,
  SERVICO:   3,
  MODELO:    4,
  VALOR:     7,
  DATA_ABER: 8,
  DATA_PROP: 9,
  VALIDADE:  10,
  FOLLOWUP:  11,
  STATUS:    12,
  CANAL:     24,
  RETORNO:   28,
  CONTATO:   30,   // AE
  EMAIL:     31,   // AF
  FONE:      32,   // AG
  OBS:       36,   // AK
  REVISAO:   37,   // AL
  FANTASIA:  38,   // AM
  ENDERECO:  39,   // AN
  CEP:       40,   // AO
  EMAIL2:    41,   // AP
  CONTATO2:  43,   // AR
};

// Cache de dados
const DATA = {
  crm:        [],
  financeiro: [],
  clientes:   [],
  projetos:   [],
  despesas:   [],
  marketing:  [],
  loaded:     false
};

let tokenClient = null;
let accessToken = null;
let gapiInited  = false;
let gisInited   = false;
let chartsInited = {};

/* ═══════════════════════════════════════════
   INIT
═══════════════════════════════════════════ */
window.addEventListener('load', () => {
  loadConfigFromStorage();
  checkConfigBanner();

  // GAPI
  gapi.load('client', async () => {
    await gapi.client.init({});
    gapiInited = true;
    maybeInit();
  });
});

// Callback do GSI
window.initGSI = function() {
  gisInited = true;
  maybeInit();
};

function maybeInit() {
  if (!gapiInited || !gisInited) return;

  // Verificar se já tem token salvo
  const saved = sessionStorage.getItem('gtoken');
  if (saved) {
    accessToken = saved;
    gapi.client.setToken({ access_token: accessToken });
    showApp();
    syncData();
    return;
  }

  // Mostrar tela de login
  document.getElementById('login-screen').style.display = 'flex';
}

function signIn() {
  if (!CONFIG.CLIENT_ID) {
    // Modo demo sem configuração
    showDemoMode();
    return;
  }

  tokenClient = google.accounts.oauth2.initTokenClient({
    client_id: CONFIG.CLIENT_ID,
    scope: CONFIG.SCOPES,
    callback: (resp) => {
      if (resp.error) { toast('Erro no login: ' + resp.error, 'error'); return; }
      accessToken = resp.access_token;
      sessionStorage.setItem('gtoken', accessToken);
      gapi.client.setToken({ access_token: accessToken });

      // Buscar info do usuário
      fetchUserInfo();
      showApp();
      syncData();
    }
  });

  tokenClient.requestAccessToken({ prompt: 'consent' });
}

function signOut() {
  if (accessToken) {
    google.accounts.oauth2.revoke(accessToken, () => {});
  }
  sessionStorage.removeItem('gtoken');
  accessToken = null;
  document.getElementById('app').style.display = 'none';
  document.getElementById('login-screen').style.display = 'flex';
  toast('Sessão encerrada', 'info');
}

async function fetchUserInfo() {
  try {
    const resp = await fetch('https://www.googleapis.com/oauth2/v2/userinfo', {
      headers: { Authorization: 'Bearer ' + accessToken }
    });
    const info = await resp.json();
    document.getElementById('user-name').textContent = info.given_name || info.name || 'Gerson';
    if (info.picture) {
      document.getElementById('user-avatar').innerHTML = `<img src="${info.picture}" alt="">`;
    } else {
      document.getElementById('user-avatar').textContent = (info.name || 'G')[0].toUpperCase();
    }
  } catch(e) {}
}

function showApp() {
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('app').style.display = 'block';
  setSyncStatus('loading', 'Sincronizando...');
}

function showDemoMode() {
  // Sem config — carregar dados de exemplo e mostrar app
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('app').style.display = 'block';
  document.getElementById('user-name').textContent = 'Gerson (Demo)';

  loadDemoData();
  setSyncStatus('ok', 'Modo demo');

  const banner = document.getElementById('config-banner');
  banner.style.display = 'block';
  banner.innerHTML = '⚠️ <strong>Modo demonstração</strong> — dados fictícios. Vá em <a href="#" onclick="nav(\'config\')">Configurações</a> para conectar sua planilha real.';

  renderAllPages();
}

/* ═══════════════════════════════════════════
   NAVIGATION
═══════════════════════════════════════════ */
const PAGE_TITLES = {
  'dashboard-crm':      'Dashboard CRM',
  'dashboard-fin':      'Dashboard Financeiro',
  'agenda':             'Agenda & Calendar',
  'pipeline':           'Pipeline Kanban',
  'crm':                'Propostas CRM',
  'nova-proposta-page': 'Nova Proposta',
  'calculadora':        'Calculadora de Proposta',
  'proposta-preview':   'Gerar Proposta PDF',
  'historico-revisoes': 'Histórico de Revisões',
  'historico-nf':       'Histórico de NFs',
  'clientes':           'Clientes',
  'projetos':           'Projetos',
  'timer':              'Timer de Horas',
  'dashboard-tempo':    'Dashboard de Tempo',
  'financeiro':         'Financeiro',
  'despesas':           'Despesas',
