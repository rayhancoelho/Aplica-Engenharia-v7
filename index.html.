<script>
/* ═══════════════════════════════════════════
   FASE 4 — FINANCEIRO COMPLETO
═══════════════════════════════════════════ */

let chartF4Anual   = null;
let chartF4RecDesp = null;
let chartDespMensal = null;

// ── HELPERS ──────────────────────────────
function f4GetMesAno(r) {
  // Tenta col 9 (data NF), depois col 0
  const d = parseDate(r[9] || r[0]);
  if (!d) return null;
  return { mes: d.getMonth(), ano: d.getFullYear(), d };
}

function f4GetValor(r) {
  return parseFloat((r[3] || '0').toString().replace(',', '.')) || 0;
}

function f4GetDespValor(r) {
  return parseFloat((r[3] || r[4] || '0').toString().replace(',', '.')) || 0;
}

function _nomeMes(m) {
  return ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'][m];
}

// ── TABS ─────────────────────────────────
function f4Tab(tab) {
  ['lista','lancar','projecao'].forEach(t => {
    const el = document.getElementById('f4-tab-' + t);
    if (el) el.style.display = t === tab ? '' : 'none';
    const btn = document.querySelector(`.fin-tab[onclick*="f4Tab('${t}')"]`);
    if (btn) btn.classList.toggle('active', t === tab);
  });
  if (tab === 'projecao') f4RenderProjecao();
}

function d4Tab(tab) {
  ['lista','lancar'].forEach(t => {
    const el = document.getElementById('d4-tab-' + t);
    if (el) el.style.display = t === tab ? '' : 'none';
    const btn = document.querySelector(`.fin-tab[onclick*="d4Tab('${t}')"]`);
    if (btn) btn.classList.toggle('active', t === tab);
  });
}

// ── KPIs FINANCEIRO ───────────────────────
function f4RenderKPIs() {
  const hoje = new Date();
  const mesAtual = hoje.getMonth();
  const anoAtual = hoje.getFullYear();
  const mesPrev  = mesAtual === 0 ? 11 : mesAtual - 1;
  const anoPrev  = mesAtual === 0 ? anoAtual - 1 : anoAtual;

  let recMes = 0, recPrev = 0, recAno = 0, nfCount = 0;
  let aReceber = 0;

  DATA.financeiro.forEach(r => {
    const v = f4GetValor(r);
    const ma = f4GetMesAno(r);
    if (!ma) return;
    if (ma.ano === anoAtual) recAno += v;
    if (ma.mes === mesAtual && ma.ano === anoAtual) {
      recMes += v;
      nfCount++;
    }
    if (ma.mes === mesPrev && ma.ano === anoPrev) recPrev += v;
    if ((r[5]||'').toLowerCase().includes('receber') || (r[5]||'').toLowerCase().includes('vencido')) {
      aReceber += v;
    }
  });

  let despMes = 0;
  DATA.despesas.forEach(r => {
    const d = parseDate(r[0]);
    if (d && d.getMonth() === mesAtual && d.getFullYear() === anoAtual) {
      despMes += f4GetDespValor(r);
    }
  });

  const resultado = recMes - despMes;
  const margem    = recMes > 0 ? (resultado / recMes * 100) : 0;
  const delta     = recPrev > 0 ? ((recMes - recPrev) / recPrev * 100) : 0;
  const ticket    = nfCount > 0 ? recAno / nfCount : 0;

  // Por mês para melhor/pior
  const recPorMes = Array(12).fill(0);
  DATA.financeiro.forEach(r => {
    const ma = f4GetMesAno(r);
    if (ma && ma.ano === anoAtual) recPorMes[ma.mes] += f4GetValor(r);
  });
  const mesesComDados = recPorMes.map((v, i) => ({v, i})).filter(x => x.v > 0);
  const melhor = mesesComDados.sort((a,b) => b.v-a.v)[0];
  const pior   = mesesComDados.sort((a,b) => a.v-b.v)[0];

  // Setar
  const s = (id, v) => { const el = document.getElementById(id); if (el) { el.textContent = v; el.classList.remove('loading-val'); } };
  s('f4-rec-mes',  fmtMoney(recMes));
  s('f4-desp-mes', fmtMoney(despMes));
  s('f4-resultado', fmtMoney(resultado));
  s('f4-margem',   margem.toFixed(1) + '%');
  s('f4-a-receber', fmtMoney(aReceber));
  s('f4-rec-ano',  fmtMoney(recAno));
  s('f4-nf-total', nfCount + ' NFs emitidas');
  s('f4-ticket',   fmtMoney(ticket));
  s('f4-melhor-mes', melhor ? _nomeMes(melhor.i) : '—');
  s('f4-pior-mes',   pior   ? _nomeMes(pior.i)   : '—');

  const deltaEl = document.getElementById('f4-rec-mes-delta');
  if (deltaEl) {
    const cor = delta >= 0 ? 'var(--green)' : 'var(--coral)';
    const sig = delta >= 0 ? '+' : '';
    deltaEl.innerHTML = `<span style="color:${cor}">${sig}${delta.toFixed(1)}%</span> vs mês anterior`;
  }

  // Colorir resultado
  const resEl = document.getElementById('f4-resultado');
  if (resEl) resEl.style.color = resultado >= 0 ? 'var(--teal)' : 'var(--coral)';

  f4RenderMeta();
}

function f4RenderMeta() {
  const meta   = parseFloat(document.getElementById('f4-meta-val')?.value || '20000') || 20000;
  const hoje   = new Date();
  const mes    = hoje.getMonth();
  const ano    = hoje.getFullYear();
  let recMes   = 0;
  DATA.financeiro.forEach(r => {
    const ma = f4GetMesAno(r);
    if (ma && ma.mes === mes && ma.ano === ano) recMes += f4GetValor(r);
  });

  const pct  = Math.min((recMes / meta * 100), 100);
  const cls  = pct >= 100 ? '' : pct >= 50 ? 'warning' : 'danger';
  const wrap = document.getElementById('f4-meta-wrap');
  if (!wrap) return;

  wrap.innerHTML = `
    <div class="meta-bar-wrap">
      <div class="meta-bar-labels">
        <span style="font-size:13px;font-weight:600">${fmtMoney(recMes)}</span>
        <span style="color:var(--text3);font-size:12px">${pct.toFixed(1)}% · Meta: ${fmtMoney(meta)}</span>
      </div>
      <div class="meta-bar-track">
        <div class="meta-bar-fill ${cls}" style="width:${pct.toFixed(1)}%"></div>
      </div>
    </div>
    <div style="font-size:11px;color:var(--text3);margin-top:6px">
      ${recMes >= meta
        ? `✅ Meta atingida! Excedente: ${fmtMoney(recMes - meta)}`
        : `Faltam ${fmtMoney(meta - recMes)} para atingir a meta`
      }
    </div>`;
}

// ── LISTA RECEITAS ────────────────────────
function renderFinanceiroTable(filtroQ = '', filtroStatus = '') {
  const tbody = document.getElementById('fin-table-body');
  if (!tbody) return;

  const rows = DATA.financeiro.filter(r => {
    const q = filtroQ.toLowerCase();
    const ok1 = !q || [r[1],r[2],r[4]].some(v => (v||'').toLowerCase().includes(q));
    const ok2 = !filtroStatus || (r[5]||'').toLowerCase().includes(filtroStatus.toLowerCase());
    return ok1 && ok2;
  });

  if (!rows.length) {
    tbody.innerHTML = `<tr><td colspan="8"><div class="empty-state" style="padding:24px"><div class="empty-icon">🧾</div><div class="empty-title">Sem receitas</div><div class="empty-sub">Lançe a primeira receita na aba "Lançar"</div></div></td></tr>`;
    return;
  }

  const statusCls = { 'pago':'fin-status-pago', 'a receber':'fin-status-receber', 'vencido':'fin-status-vencido', 'cancelado':'fin-status-cancelado' };

  tbody.innerHTML = rows.map(r => {
    const status = (r[5]||'').toLowerCase();
    const cls    = statusCls[status] || 'fin-status-receber';
    const valor  = f4GetValor(r);
    return `<tr>
      <td class="text-dim">${r[9]||r[0]||'—'}</td>
      <td style="font-weight:600">${(r[1]||'—').slice(0,28)}</td>
      <td class="text-muted" style="font-size:12px">${(r[4]||'—').slice(0,22)}</td>
      <td class="text-teal font-mono fw-bold">${fmtMoney(valor)}</td>
      <td class="text-dim">${r[2]||'—'}</td>
      <td class="text-dim">${r[6]||'—'}</td>
      <td><span class="${cls}">${r[5]||'—'}</span></td>
      <td>
        <button class="btn btn-ghost btn-sm" style="padding:2px 8px;font-size:11px"
          onclick="f4MarcarPago(this)" data-row='${JSON.stringify(r)}'>✓ Pago</button>
      </td>
    </tr>`;
  }).join('');
}

function f4FiltrarReceitas(q) {
  const q2     = typeof q === 'string' ? q : '';
  const status = document.getElementById('f4-filtro-status')?.value || '';
  renderFinanceiroTable(q2, status);
}

function f4MarcarPago(btn) {
  try {
    const r = JSON.parse(btn.dataset.row);
    const idx = DATA.financeiro.findIndex(x => x[2] === r[2] && x[1] === r[1]);
    if (idx >= 0) {
      DATA.financeiro[idx][5] = 'Pago';
      renderFinanceiroTable();
      f4RenderKPIs();
      toast('✅ Marcado como pago', 'success');
    }
  } catch(e) {}
}

// ── LANÇAR RECEITA ────────────────────────
function f4PopularCRMSelect() {
  const sel = document.getElementById('f4-crm-vinculo');
  if (!sel) return;
  sel.innerHTML = '<option value="">— Selecionar proposta ganha —</option>';
  DATA.crm.filter(r => r[CRM_COL.STATUS] === 'Ganha').forEach((r, i) => {
    const opt = document.createElement('option');
    opt.value = DATA.crm.indexOf(r);
    opt.textContent = `#${String(r[CRM_COL.ID]||i+1).padStart(4,'0')} — ${(r[CRM_COL.RAZAO]||'').slice(0,30)} — ${fmtMoney(parseFloat((r[CRM_COL.VALOR]||'0').toString().replace(',','.'))||0)}`;
    sel.appendChild(opt);
  });
}

function f4VincularCRM() {
  const idx = parseInt(document.getElementById('f4-crm-vinculo')?.value);
  if (isNaN(idx)) return;
  const r = DATA.crm[idx];
  if (!r) return;
  const s = (id, v) => { const el = document.getElementById(id); if (el) el.value = v || ''; };
  s('f4-cliente', r[CRM_COL.RAZAO]);
