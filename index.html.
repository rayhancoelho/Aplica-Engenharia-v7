function maskCNPJ(el) {
  let v = el.value.replace(/\D/g,'').slice(0,14);
  if (v.length > 12) v = v.slice(0,2)+'.'+v.slice(2,5)+'.'+v.slice(5,8)+'/'+v.slice(8,12)+'-'+v.slice(12);
  else if (v.length > 8) v = v.slice(0,2)+'.'+v.slice(2,5)+'.'+v.slice(5,8)+'/'+v.slice(8);
  else if (v.length > 5) v = v.slice(0,2)+'.'+v.slice(2,5)+'.'+v.slice(5);
  else if (v.length > 2) v = v.slice(0,2)+'.'+v.slice(2);
  el.value = v;
}

async function lookupCNPJ() {
  const el = document.getElementById('np-cnpj');
  if (!el) return;
  const cnpj = el.value.replace(/\D/g,'');
  if (cnpj.length !== 14) return;

  document.getElementById('cnpj-loading').style.display = 'block';
  try {
    await _fetchCNPJData(cnpj, {
      razao:    'np-razao',
      fantasia: 'np-fantasia',
      endereco: 'np-endereco',
      municipio:'np-municipio',
    }, 'cnpj-preview');
  } finally {
    document.getElementById('cnpj-loading').style.display = 'none';
  }
}

