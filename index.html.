/* ═══════════════════════════════════════════
   FASE 1.1 — PIPELINE KANBAN
═══════════════════════════════════════════ */
const KANBAN_COLS = [
  { id: 'Em prospecção', label: 'Prospecção',    color: '#4493f8', icon: '🔵' },
  { id: 'Enviada',       label: 'Enviada',        color: '#f0a500', icon: '📤' },
  { id: 'Em Negociação', label: 'Em Negociação',  color: '#bc8cff', icon: '🤝' },
  { id: 'Ganha',         label: 'Ganha',          color: '#3fb950', icon: '✅' },
  { id: 'Perdida',       label: 'Perdida',        color: '#f85149', icon: '❌' },
];

let pipeFilter = { q: '', serv: '' };
let dragSrcIdx = null;
let dragSrcStatus = null;

function renderPipeline() {
  const board = document.getElementById('kanban-board');
  if (!board) return;

  const rows = getPipelineRows();
  const hoje = new Date(); hoje.setHours(0,0,0,0);

  board.innerHTML = KANBAN_COLS.map(col => {
    const cards = rows.filter(r => (r[CRM_COL.STATUS] || '') === col.id);
    const total = cards.reduce((s, r) => s + (parseFloat((r[CRM_COL.VALOR]||'0').replace(',','.')) || 0), 0);

    const cardsHtml = cards.length === 0
      ? `<div class="kanban-drop-zone" id="drop-${col.id.replace(/ /g,'_')}" ondragover="pipeDragOver(event,'${col.id}')" ondrop="pipeDrop(event,'${col.id}')" ondragleave="pipeDragLeave(event)">Arraste aqui</div>`
      : cards.map((r, i) => {
          const realIdx = DATA.crm.indexOf(r);
          const vd = parseDate(r[CRM_COL.VALIDADE]);
          let diasClass = 'ok', diasLabel = '';
          if (vd) {
            const diff = Math.ceil((vd - hoje) / 86400000);
            if (diff < 0)      { diasClass = 'expired'; diasLabel = `Venceu ${Math.abs(diff)}d`; }
            else if (diff <= 3) { diasClass = 'urgent';  diasLabel = `${diff}d`; }
            else if (diff <= 7) { diasClass = 'warning'; diasLabel = `${diff}d`; }
            else                { diasClass = 'ok';      diasLabel = `${diff}d`; }
          }

          const cardClass = diasClass === 'urgent' ? 'urgent' : diasClass === 'warning' ? 'warning' : 'ok';
          const cliente = (r[CRM_COL.RAZAO] || '—').slice(0, 26);
          const servico = (r[CRM_COL.SERVICO] || '—').slice(0, 30);
          const valor   = parseFloat((r[CRM_COL.VALOR]||'0').replace(',','.')) || 0;

          return `<div class="kanban-card ${cardClass}"
            draggable="true"
            ondragstart="pipeDragStart(event, ${realIdx}, '${col.id}')"
            ondragover="pipeDragOver(event,'${col.id}')"
            ondrop="pipeDrop(event,'${col.id}')"
            ondragleave="pipeDragLeave(event)"
            ondblclick="abrirEditar(${realIdx})"
            title="Duplo clique para editar">
            <div class="kcard-cliente">${cliente}</div>
            <div class="kcard-servico">${servico}</div>
            <div class="kcard-bottom">
              <span class="kcard-valor">${fmtMoney(valor)}</span>
              ${diasLabel ? `<span class="kcard-dias ${diasClass}">${diasLabel}</span>` : ''}
            </div>
          </div>`;
        }).join('') + `<div class="kanban-drop-zone" style="margin-top:6px" id="drop-bottom-${col.id.replace(/ /g,'_')}" ondragover="pipeDragOver(event,'${col.id}')" ondrop="pipeDrop(event,'${col.id}')" ondragleave="pipeDragLeave(event)">+ Soltar aqui</div>`;

    return `<div class="kanban-col">
      <div class="kanban-col-header">
        <div class="kanban-col-title">
          <span style="color:${col.color}">${col.icon}</span>
          ${col.label}
          <span class="kanban-col-count">${cards.length}</span>
        </div>
        ${total > 0 ? `<span class="kanban-col-total">${fmtMoney(total)}</span>` : ''}
      </div>
      <div class="kanban-cards">${cardsHtml}</div>
    </div>`;
  }).join('');
}

function getPipelineRows() {
  return DATA.crm.filter(r => {
    const q    = pipeFilter.q.toLowerCase();
    const serv = pipeFilter.serv;
    const matchQ    = !q    || [r[CRM_COL.RAZAO],r[CRM_COL.SERVICO]].some(v => (v||'').toLowerCase().includes(q));
    const matchServ = !serv || (r[CRM_COL.SERVICO]||'').toUpperCase().includes(serv.split(' ')[0]);
    return matchQ && matchServ;
  });
}

function filterPipeline() {
  pipeFilter.q    = document.getElementById('pipe-search')?.value    || '';
  pipeFilter.serv = document.getElementById('pipe-filter-serv')?.value || '';
  renderPipeline();
}

// Drag & Drop
function pipeDragStart(e, idx, status) {
  dragSrcIdx    = idx;
  dragSrcStatus = status;
  e.dataTransfer.effectAllowed = 'move';
  setTimeout(() => { if (e.target) e.target.classList.add('dragging'); }, 0);
}

function pipeDragOver(e, targetStatus) {
  e.preventDefault();
  e.dataTransfer.dropEffect = 'move';
  e.currentTarget.classList.add('over');
}

function pipeDragLeave(e) {
  e.currentTarget.classList.remove('over');
}

async function pipeDrop(e, targetStatus) {
  e.preventDefault();
  e.currentTarget.classList.remove('over');

  if (dragSrcIdx === null || dragSrcStatus === targetStatus) return;

  const novoStatus  = targetStatus;
  const idx         = dragSrcIdx;
  const statusAntes = DATA.crm[idx]?.[CRM_COL.STATUS];

  // Atualizar cache
  if (DATA.crm[idx]) DATA.crm[idx][CRM_COL.STATUS] = novoStatus;

  // Re-renderizar imediatamente
  renderPipeline();
  renderDashboardCRM();
  renderCRMTable();

  // Salvar no Sheets
  if (CONFIG.SHEET_ID && accessToken) {
    try {
      const rowReal = idx + 2;
      const range = `${CONFIG.SHEETS.CRM}!M${rowReal}`;
      const url   = `https://sheets.googleapis.com/v4/spreadsheets/${CONFIG.SHEET_ID}/values/${encodeURIComponent(range)}?valueInputOption=USER_ENTERED`;
      await fetch(url, {
        method: 'PUT',
        headers: { Authorization: 'Bearer ' + accessToken, 'Content-Type': 'application/json' },
        body: JSON.stringify({ values: [[novoStatus]] })
      });
      toast(`✅ Movido para "${novoStatus}"`, 'success');
    } catch(err) {
      toast('Erro ao salvar status: ' + err.message, 'error');
    }
  } else {
    toast(`Movido para "${novoStatus}" (demo)`, 'info');
  }

  // Transferência automática ao mover para Ganha
  if (novoStatus === 'Ganha' && statusAntes !== 'Ganha' && DATA.crm[idx]) {
    await transferirParaFinanceiro(DATA.crm[idx]);
  }

  dragSrcIdx = null;
}

