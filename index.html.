        { range: `${CONFIG.SHEETS.CRM}!B${rowReal}`,  values: [[r[CRM_COL.CNPJ]]]     },
        { range: `${CONFIG.SHEETS.CRM}!C${rowReal}`,  values: [[r[CRM_COL.RAZAO]]]    },
