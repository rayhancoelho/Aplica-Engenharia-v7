/* ═══════════════════════════════════════════
   FASE 1.3 — CALCULADORA DE PROPOSTA
═══════════════════════════════════════════ */
let calcItens = [];

function calcInit() {
  if (calcItens.length === 0) {
    calcItens = [
      { desc: '', qtd: 1, horas: 0 },
      { desc: '', qtd: 1, horas: 0 },
      { desc: '', qtd: 1, horas: 0 },
    ];
  }
  renderCalcItens();
