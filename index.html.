        { range: `${CONFIG.SHEETS.CRM}!AK${rowReal}`, values: [[r[CRM_COL.OBS]]]      },
      ];

      const url = `https://sheets.googleapis.com/v4/spreadsheets/${CONFIG.SHEET_ID}/values:batchUpdate`;
