  const statusAnterior = r[CRM_COL.STATUS];

  // Atualizar cache local
  r[CRM_COL.CNPJ]     = get('edit-cnpj');
  r[CRM_COL.RAZAO]    = get('edit-razao');
  r[CRM_COL.SERVICO]  = get('edit-servico');
