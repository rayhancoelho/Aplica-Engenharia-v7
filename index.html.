function renderCalcItens() {
  const tbody = document.getElementById('calc-items-body');
  if (!tbody) return;

  const vh = parseFloat(document.getElementById('calc-vh')?.value || '200') || 200;

  tbody.innerHTML = calcItens.map((item, i) => {
    const valorItem = (item.qtd || 0) * (item.horas || 0) * vh;
    return `<tr>
      <td style="color:var(--text3);text-align:center">${i+1}</td>
      <td><input value="${item.desc}" placeholder="Descrição do serviço/item"
        oninput="calcItens[${i}].desc=this.value"></td>
      <td><input type="number" value="${item.qtd}" min="0" step="0.5"
        oninput="calcItens[${i}].qtd=parseFloat(this.value)||0;calcRecalcular()" style="text-align:center"></td>
      <td><input type="number" value="${item.horas}" min="0" step="0.5"
        oninput="calcItens[${i}].horas=parseFloat(this.value)||0;calcRecalcular()" style="text-align:center"></td>
      <td><div class="val-auto">${fmtMoney(valorItem)}</div></td>
      <td><button style="background:none;border:none;color:var(--coral);cursor:pointer;font-size:14px;padding:4px"
        onclick="calcRemoveItem(${i})">×</button></td>
    </tr>`;
  }).join('');
}

function calcAddItem() {
  calcItens.push({ desc: '', qtd: 1, horas: 0 });
  renderCalcItens();
  calcRecalcular();
}

function calcRemoveItem(i) {
  calcItens.splice(i, 1);
  renderCalcItens();
  calcRecalcular();
}

function calcRecalcular() {
  const vh    = parseFloat(document.getElementById('calc-vh')?.value)     || 200;
  const art   = parseFloat(document.getElementById('calc-art')?.value)    || 0;
  const desc  = parseFloat(document.getElementById('calc-desc')?.value)   || 0;
  const imp   = parseFloat(document.getElementById('calc-imp')?.value)    || 6;
  const km    = parseFloat(document.getElementById('calc-km')?.value)     || 0;
  const rkm   = parseFloat(document.getElementById('calc-rkm')?.value)    || 0.8;
  const vis   = parseFloat(document.getElementById('calc-vis')?.value)    || 1;
  const extras= parseFloat(document.getElementById('calc-extras')?.value) || 0;

  // Calcular itens
  let subtotal = 0;
  let totalH   = 0;
  calcItens.forEach(item => {
    const v = (item.qtd || 0) * (item.horas || 0) * vh;
    subtotal += v;
    totalH   += (item.qtd || 0) * (item.horas || 0);
  });

  const desl  = km * rkm * vis;
  const bruto = subtotal + art + desl + extras;
  const impVal= bruto * (imp / 100);
  const liq   = bruto - impVal;
  const descVal = liq * (desc / 100);
  const comDesc = liq - descVal;
  const margem  = bruto > 0 ? ((liq - art - desl - extras) / bruto * 100) : 0;

  const s = id => document.getElementById(id);
  if (s('r-subtotal')) s('r-subtotal').textContent = fmtMoney(subtotal);
  if (s('r-art'))      s('r-art').textContent      = fmtMoney(art);
  if (s('r-desl'))     s('r-desl').textContent     = fmtMoney(desl);
  if (s('r-extras'))   s('r-extras').textContent   = fmtMoney(extras);
  if (s('r-bruto'))    s('r-bruto').textContent     = fmtMoney(bruto);
  if (s('r-imp'))      s('r-imp').textContent       = '− ' + fmtMoney(impVal);
  if (s('r-liq'))      s('r-liq').textContent       = fmtMoney(liq);
  if (s('r-desc'))     s('r-desc').textContent      = fmtMoney(comDesc) + ` (−${desc}%)`;
  if (s('r-horas'))    s('r-horas').textContent     = totalH.toFixed(1) + 'h';
  if (s('r-margem'))   s('r-margem').textContent    = margem.toFixed(1) + '%';
  if (s('r-desl-mem')) s('r-desl-mem').textContent  = `${km} km × R$${rkm}/km × ${vis} vis.`;

  renderCalcItens();
}

function calcReset() {
  calcItens = [{ desc:'', qtd:1, horas:0 }, { desc:'', qtd:1, horas:0 }, { desc:'', qtd:1, horas:0 }];
  ['calc-id-proposta','calc-cliente','calc-num-proposta'].forEach(id => {
    const el = document.getElementById(id); if (el) el.value = '';
  });
  renderCalcItens();
  calcRecalcular();
}

async function calcSalvarNoSheets() {
  const idProp = parseInt(document.getElementById('calc-id-proposta')?.value || '0');
  if (!idProp) { toast('Vincule uma proposta do CRM primeiro', 'warning'); return; }

  const vh    = parseFloat(document.getElementById('calc-vh')?.value)  || 200;
  const art   = parseFloat(document.getElementById('calc-art')?.value) || 0;
  const imp   = parseFloat(document.getElementById('calc-imp')?.value) || 6;
  const km    = parseFloat(document.getElementById('calc-km')?.value)  || 0;
  const rkm   = parseFloat(document.getElementById('calc-rkm')?.value) || 0.8;
  const vis   = parseFloat(document.getElementById('calc-vis')?.value) || 1;
  const extras= parseFloat(document.getElementById('calc-extras')?.value) || 0;

  let subtotal = 0;
  calcItens.forEach(item => { subtotal += (item.qtd||0) * (item.horas||0) * vh; });
  const desl  = km * rkm * vis;
  const bruto = subtotal + art + desl + extras;
  const liq   = bruto - bruto * (imp/100);

  const idx = DATA.crm.findIndex(r => parseInt(r[CRM_COL.ID]) === idProp);
  if (idx < 0) { toast('Proposta não encontrada no cache', 'error'); return; }

  DATA.crm[idx][CRM_COL.VALOR] = liq.toFixed(2);

  if (CONFIG.SHEET_ID && accessToken) {
    try {
      const rowReal = idx + 2;
      const url = `https://sheets.googleapis.com/v4/spreadsheets/${CONFIG.SHEET_ID}/values/${encodeURIComponent(CONFIG.SHEETS.CRM + '!H' + rowReal)}?valueInputOption=USER_ENTERED`;
      await fetch(url, {
        method: 'PUT',
        headers: { Authorization: 'Bearer ' + accessToken, 'Content-Type': 'application/json' },
        body: JSON.stringify({ values: [[liq.toFixed(2)]] })
      });
      toast(`✅ Valor R$ ${liq.toFixed(2)} salvo na proposta #${idProp}`, 'success');
    } catch(e) {
      toast('Erro: ' + e.message, 'error');
    }
  } else {
    toast(`Valor ${fmtMoney(liq)} salvo na proposta #${idProp} (demo)`, 'success');
  }

  renderDashboardCRM();
  renderCRMTable();
  renderPipeline();
}

