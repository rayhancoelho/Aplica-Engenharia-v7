}

function d4RenderKPIs() {
  const hoje   = new Date();
  const mes    = hoje.getMonth();
  const ano    = hoje.getFullYear();

  let total = 0, fixas = 0, variaveis = 0;
  const catCount = {};

  DATA.despesas.forEach(r => {
    const d = parseDate(r[0]);
    if (!d || d.getMonth() !== mes || d.getFullYear() !== ano) return;
    const v = f4GetDespValor(r);
    total += v;
    if ((r[6]||'').toLowerCase() === 'fixa') fixas += v;
    else variaveis += v;
    const cat = r[2] || 'Outros';
    catCount[cat] = (catCount[cat] || 0) + v;
  });

  const topCat = Object.entries(catCount).sort((a,b) => b[1]-a[1])[0]?.[0] || '—';

  const s = (id, v) => { const el = document.getElementById(id); if (el) { el.textContent = v; el.classList.remove('loading-val'); } };
  s('d4-total-mes', fmtMoney(total));
  s('d4-fixas',     fmtMoney(fixas));
  s('d4-variaveis', fmtMoney(variaveis));
  s('d4-top-cat',   topCat.length > 14 ? topCat.slice(0,12)+'…' : topCat);
}

// ── PROJEÇÃO / GRÁFICOS ───────────────────
function f4RenderProjecao() {
  const hoje = new Date();
  const mes  = hoje.getMonth();
  const ano  = hoje.getFullYear();

  // Receita por mês (ano atual)
  const recPorMes  = Array(12).fill(0);
  const despPorMes = Array(12).fill(0);

  DATA.financeiro.forEach(r => {
    const ma = f4GetMesAno(r);
    if (ma && ma.ano === ano) recPorMes[ma.mes] += f4GetValor(r);
  });
  DATA.despesas.forEach(r => {
    const d = parseDate(r[0]);
    if (d && d.getFullYear() === ano) despPorMes[d.getMonth()] += f4GetDespValor(r);
  });

  // Média dos últimos 3 meses reais para projeção
  const mesesReais = recPorMes.slice(0, mes + 1).filter(v => v > 0);
  const mediaRec   = mesesReais.length > 0 ? mesesReais.slice(-3).reduce((s,v) => s+v, 0) / Math.min(3, mesesReais.length) : 0;
  const mediaDes   = despPorMes.slice(0, mes + 1).filter(v => v > 0).slice(-3).reduce((s,v) => s+v, 0) / 3 || 0;

  // Proj 3 meses
  const projEl = document.getElementById('f4-proj-meses');
  if (projEl) {
    const meses3 = [-1, 0, 1, 2].map(offset => {
      const m = (mes + offset + 12) % 12;
      const rec  = offset < 0 ? recPorMes[m]  : (offset === 0 ? recPorMes[m]  : mediaRec);
      const desp = offset < 0 ? despPorMes[m] : (offset === 0 ? despPorMes[m] : mediaDes);
      return { label: _nomeMes(m), rec, desp, res: rec - desp, isMes: offset === 0, isFut: offset > 0 };
    });
    projEl.innerHTML = meses3.slice(1).map(m => `
      <div class="proj-mes ${m.isMes ? 'atual' : m.isFut ? 'futuro' : ''}">
        <div class="proj-mes-label">${m.label}${m.isMes ? ' (atual)' : m.isFut ? ' (proj.)' : ''}</div>
        <div class="proj-mes-rec">${fmtMoney(m.rec)}</div>
        <div class="proj-mes-desp">↓ ${fmtMoney(m.desp)} desp.</div>
        <div class="proj-mes-res ${m.res >= 0 ? 'pos' : 'neg'}">${m.res >= 0 ? '+' : ''}${fmtMoney(m.res)}</div>
      </div>`).join('');
  }

  // Gráfico acumulado anual
  const ctx1 = document.getElementById('chartF4Anual');
  if (ctx1) {
    if (chartF4Anual) chartF4Anual.destroy();
    const acum = recPorMes.slice(0, mes + 1).reduce((acc, v) => {
      acc.push((acc.length ? acc[acc.length-1] : 0) + v); return acc;
    }, []);
    chartF4Anual = new Chart(ctx1, {
      type: 'line',
      data: {
        labels: ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'].slice(0, mes + 1),
        datasets: [{
          data: acum,
          borderColor: '#2ec4a0', backgroundColor: 'rgba(46,196,160,0.08)',
          fill: true, tension: 0.4, pointRadius: 4, pointBackgroundColor: '#2ec4a0',
        }]
      },
      options: {
        responsive: true,
        plugins: { legend: { display: false }, tooltip: { callbacks: { label: c => fmtMoney(c.parsed.y) } } },
        scales: {
          x: { grid: { color: '#21262d' }, ticks: { color: '#8b949e', font: { size: 11 } } },
          y: { grid: { color: '#21262d' }, ticks: { color: '#8b949e', font: { size: 11 }, callback: v => fmtMoney(v) } }
        }
      }
    });
  }

  // Gráfico Rec vs Desp últimos 6 meses
  const ctx2 = document.getElementById('chartF4RecDesp');
  if (ctx2) {
    if (chartF4RecDesp) chartF4RecDesp.destroy();
    const ultimos6 = Array.from({length: 6}, (_, i) => (mes - 5 + i + 12) % 12);
    chartF4RecDesp = new Chart(ctx2, {
      type: 'bar',
      data: {
        labels: ultimos6.map(_nomeMes),
        datasets: [
          { label: 'Receita',  data: ultimos6.map(m => recPorMes[m]),  backgroundColor: 'rgba(46,196,160,0.7)',  borderRadius: 4, borderSkipped: false },
          { label: 'Despesas', data: ultimos6.map(m => despPorMes[m]), backgroundColor: 'rgba(248,81,73,0.6)',   borderRadius: 4, borderSkipped: false },
        ]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { labels: { color: '#8b949e', font: { size: 11 } } },
          tooltip: { callbacks: { label: c => c.dataset.label + ': ' + fmtMoney(c.parsed.y) } }
        },
        scales: {
          x: { grid: { color: '#21262d' }, ticks: { color: '#8b949e', font: { size: 11 } } },
          y: { grid: { color: '#21262d' }, ticks: { color: '#8b949e', font: { size: 11 }, callback: v => fmtMoney(v) } }
        }
      }
    });
  }

  // Gráfico despesas mensal
  const ctx3 = document.getElementById('chartDespMensal');
  if (ctx3) {
    if (chartDespMensal) chartDespMensal.destroy();
    chartDespMensal = new Chart(ctx3, {
      type: 'line',
      data: {
        labels: ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'].slice(0, mes + 1),
        datasets: [{
          data: despPorMes.slice(0, mes + 1),
          borderColor: '#f85149', backgroundColor: 'rgba(248,81,73,0.07)',
          fill: true, tension: 0.4, pointRadius: 3, pointBackgroundColor: '#f85149',
        }]
      },
      options: {
        responsive: true,
        plugins: { legend: { display: false }, tooltip: { callbacks: { label: c => fmtMoney(c.parsed.y) } } },
        scales: {
          x: { grid: { color: '#21262d' }, ticks: { color: '#8b949e', font: { size: 11 } } },
          y: { grid: { color: '#21262d' }, ticks: { color: '#8b949e', font: { size: 11 }, callback: v => fmtMoney(v) } }
        }
      }
    });
  }
}

