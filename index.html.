<script>
/* ═══════════════════════════════════════════
   FASE 5 — MARKETING COMPLETO
═══════════════════════════════════════════ */
let DATA_campanhas = [];
let DATA_leads     = [];

// ── MARKETING ──
function renderMarketing() {
  // KPIs
  const totalInv  = DATA.marketing.reduce((s,r) => s + (parseFloat((r[2]||'0').replace(',','.'))||0), 0)
                  + DATA_campanhas.reduce((s,c) => s + (c.inv||0), 0);
  const totalLeads= DATA.marketing.reduce((s,r) => s + (parseInt(r[3])||0), 0)
                  + DATA_campanhas.reduce((s,c) => s + (c.leads||0), 0);
  const totalRec  = DATA.marketing.reduce((s,r) => s + (parseFloat((r[5]||'0').replace(',','.'))||0), 0)
                  + DATA_campanhas.reduce((s,c) => s + (c.rec||0), 0);
  const roi       = totalInv > 0 ? ((totalRec - totalInv) / totalInv * 100) : 0;

  const s = id => document.getElementById(id);
  if (s('mkt-kpi-inv'))   s('mkt-kpi-inv').textContent   = fmtMoney(totalInv);
  if (s('mkt-kpi-leads')) s('mkt-kpi-leads').textContent = totalLeads;
  if (s('mkt-kpi-rec'))   s('mkt-kpi-rec').textContent   = fmtMoney(totalRec);
  if (s('mkt-kpi-roi'))   s('mkt-kpi-roi').textContent   = roi.toFixed(0) + '%';

  // Campanhas
  const todasCamp = [
    ...DATA.marketing.map((r,i) => ({
      nome: r[0]||'—', canal: r[1]||'—',
      inv: parseFloat((r[2]||'0').replace(',','.'))||0,
      leads: parseInt(r[3])||0, props: parseInt(r[4])||0,
      rec: parseFloat((r[5]||'0').replace(',','.'))||0,
      _sheets: true, idx: i
    })),
    ...DATA_campanhas.map((c,i) => ({...c, _local: true, idx: i}))
  ];

  const lista = document.getElementById('mkt-campanhas-list');
  if (!lista) return;
  if (!todasCamp.length) {
    lista.innerHTML = `<div class="empty-state" style="padding:24px"><div class="empty-icon">📣</div><div class="empty-sub">Nenhuma campanha cadastrada</div></div>`;
  } else {
    lista.innerHTML = todasCamp.map(c => {
      const roi  = c.inv > 0 ? ((c.rec - c.inv) / c.inv * 100) : 0;
      const cpl  = c.leads > 0 ? c.inv / c.leads : 0;
      const conv = c.leads > 0 ? (c.props / c.leads * 100) : 0;
      return `<div class="roi-card">
        <div>
          <div class="roi-nome">${c.nome}</div>
          <div class="roi-canal">${c.canal} · Inv: ${fmtMoney(c.inv)} · ${c.leads} leads</div>
        </div>
        <div style="text-align:right">
          <div class="roi-num ${roi >= 0 ? 'positivo':'negativo'}">${roi >= 0?'+':''}${roi.toFixed(0)}% ROI</div>
          <div class="roi-detalhe">CPL: ${fmtMoney(cpl)} · Conv: ${conv.toFixed(0)}%</div>
        </div>
      </div>`;
    }).join('');
  }

  // Canais CRM
  const canaisMap = {};
  DATA.crm.forEach(r => {
    const canal = r[24] || 'Direto';
    canaisMap[canal] = (canaisMap[canal]||0) + 1;
  });
  const totalCRM = DATA.crm.length || 1;
  const canaisDiv = document.getElementById('mkt-canais-list');
  if (canaisDiv) {
    const cores = ['var(--gold)','var(--teal)','var(--steel)','var(--lavender)','var(--coral)','var(--green)'];
    canaisDiv.innerHTML = Object.entries(canaisMap)
      .sort((a,b) => b[1]-a[1])
      .map(([canal, cnt], i) => `
        <div class="funil-barra">
          <span class="funil-label">${canal}</span>
          <div class="funil-track">
            <div class="funil-fill" style="width:${(cnt/totalCRM*100).toFixed(0)}%;background:${cores[i%cores.length]}">${cnt}</div>
          </div>
          <span class="funil-num">${(cnt/totalCRM*100).toFixed(0)}%</span>
        </div>`).join('');
  }

  // Funil
  const total     = DATA.crm.length;
  const prosp     = DATA.crm.filter(r => r[CRM_COL.STATUS]==='Em prospecção').length;
  const env       = DATA.crm.filter(r => r[CRM_COL.STATUS]==='Enviada').length;
  const neg       = DATA.crm.filter(r => r[CRM_COL.STATUS]==='Em Negociação').length;
  const ganhas    = DATA.crm.filter(r => r[CRM_COL.STATUS]==='Ganha').length;
  const funilDiv  = document.getElementById('mkt-funil');
  if (funilDiv) {
    const etapas = [
      { label:'Total Propostas', cnt: total,  cor:'var(--steel)' },
      { label:'Enviadas',        cnt: env+neg, cor:'var(--gold)' },
      { label:'Em Negociação',   cnt: neg,     cor:'var(--lavender)' },
      { label:'Ganhas',          cnt: ganhas,  cor:'var(--green)' },
    ];
    funilDiv.innerHTML = etapas.map(e => `
      <div class="funil-barra">
        <span class="funil-label">${e.label}</span>
        <div class="funil-track">
          <div class="funil-fill" style="width:${total>0?(e.cnt/total*100).toFixed(0):0}%;background:${e.cor}">${e.cnt}</div>
        </div>
        <span class="funil-num">${e.cnt}</span>
      </div>`).join('');
  }

  // CPL por canal
  const cplDiv = document.getElementById('mkt-cpl-list');
  if (cplDiv) {
    const cplMap = {};
    todasCamp.forEach(c => {
      if (!cplMap[c.canal]) cplMap[c.canal] = { inv: 0, leads: 0 };
      cplMap[c.canal].inv   += c.inv;
      cplMap[c.canal].leads += c.leads;
    });
    cplDiv.innerHTML = Object.entries(cplMap).map(([canal, v]) => {
      const cpl = v.leads > 0 ? v.inv / v.leads : 0;
      return `<div style="display:flex;justify-content:space-between;font-size:12px">
        <span style="color:var(--text2)">${canal}</span>
        <span class="font-mono fw-bold" style="color:var(--lavender)">${fmtMoney(cpl)}/lead</span>
      </div>`;
    }).join('') || '<div class="text-dim" style="font-size:12px">Nenhuma campanha com dados de leads</div>';
  }
}

async function salvarCampanha() {
  const nome   = document.getElementById('camp-nome')?.value    || '';
  const canal  = document.getElementById('camp-canal')?.value   || '';
  const periodo= document.getElementById('camp-periodo')?.value || '';
  const inv    = parseFloat(document.getElementById('camp-inv')?.value  || '0') || 0;
  const leads  = parseInt(document.getElementById('camp-leads')?.value  || '0') || 0;
  const props  = parseInt(document.getElementById('camp-props')?.value  || '0') || 0;
  const rec    = parseFloat(document.getElementById('camp-rec')?.value  || '0') || 0;
  const obs    = document.getElementById('camp-obs')?.value     || '';

  if (!nome) { toast('Informe o nome da campanha', 'warning'); return; }

  const camp = { nome, canal, periodo, inv, leads, props, rec, obs, data: new Date().toLocaleDateString('pt-BR') };
  DATA_campanhas.push(camp);

  if (CONFIG.SHEET_ID && accessToken) {
    try {
      await sheetsAppend('MARKETING', [[camp.data, nome, canal, inv, leads, props, rec, obs]]);
      toast('✅ Campanha salva no Sheets!', 'success');
    } catch(e) { toast('Campanha salva localmente', 'warning'); }
  } else {
    toast('Campanha salva (demo)', 'success');
  }

  closeModal('modal-nova-campanha');
  renderMarketing();
  ['camp-nome','camp-periodo','camp-inv','camp-leads','camp-props','camp-rec','camp-obs'].forEach(id => {
    const el = document.getElementById(id); if (el) el.value = '';
  });
}

// ── PROSPECÇÃO DE LEADS ──
function renderLeads(filtro = '') {
  const temp   = document.getElementById('lead-filter-temp')?.value || '';
  let lista    = DATA_leads;
  if (filtro) {
    const q = filtro.toLowerCase();
    lista = lista.filter(l => [l.empresa, l.contato, l.obs, l.servico].some(v => (v||'').toLowerCase().includes(q)));
  }
  if (temp) lista = lista.filter(l => l.temp === temp);

  // Contadores
  const s = id => document.getElementById(id);
  if (s('lead-cnt-q')) s('lead-cnt-q').textContent = DATA_leads.filter(l=>l.temp==='quente').length;
  if (s('lead-cnt-m')) s('lead-cnt-m').textContent = DATA_leads.filter(l=>l.temp==='morno').length;
  if (s('lead-cnt-f')) s('lead-cnt-f').textContent = DATA_leads.filter(l=>l.temp==='frio').length;
  if (s('lead-cnt-t')) s('lead-cnt-t').textContent = DATA_leads.length;

  // Badge sidebar
  const badge = document.getElementById('badge-prosp');
  if (badge) {
    const quentes = DATA_leads.filter(l => l.temp === 'quente').length;
    badge.textContent = quentes;
    badge.style.display = quentes ? '' : 'none';
  }

  // Lista
  const container = document.getElementById('leads-list');
  if (!container) return;
  if (!lista.length) {
    container.innerHTML = `<div class="empty-state"><div class="empty-icon">🎯</div><div class="empty-title">Nenhum lead</div><div class="empty-sub">${filtro||temp ? 'Nenhum resultado para o filtro.' : 'Adicione leads para acompanhar.'}</div></div>`;
    return;
  }

  const tempIcons = { quente:'🔴', morno:'🟡', frio:'🔵' };
  container.innerHTML = lista.map((l, i) => {
    const hoje = new Date(); hoje.setHours(0,0,0,0);
    const fu   = l.followup ? new Date(l.followup + 'T00:00:00') : null;
    const fuLabel = fu ? (() => {
      const diff = Math.ceil((fu - hoje) / 86400000);
      if (diff < 0)  return `<span style="color:var(--coral)">Venceu ${Math.abs(diff)}d</span>`;
      if (diff === 0) return `<span style="color:var(--gold)">Hoje</span>`;
      return `<span style="color:var(--text3)">${diff}d</span>`;
    })() : '';

    return `<div class="lead-card ${l.temp||'morno'}">
      <div class="lead-temp ${l.temp||'morno'}">${tempIcons[l.temp]||'🟡'}</div>
      <div class="lead-body">
        <div class="lead-empresa">${l.empresa||'—'}</div>
        <div class="lead-servico">${l.servico||'—'} · ${l.canal||'—'}</div>
        <div class="lead-meta">
          ${l.contato ? `<span>👤 ${l.contato}</span>` : ''}
          ${l.fone    ? `<span>📱 ${l.fone}</span>` : ''}
          ${l.valor   ? `<span>💰 ${fmtMoney(l.valor)}</span>` : ''}
          ${fuLabel   ? `<span>📅 Follow-up: ${fuLabel}</span>` : ''}
        </div>
        ${l.obs ? `<div style="font-size:11px;color:var(--text3);margin-top:6px;font-style:italic">${l.obs.slice(0,80)}${l.obs.length>80?'…':''}</div>` : ''}
      </div>
      <div class="lead-actions">
        <button class="btn btn-primary btn-sm" onclick="converterLeadIdx(${DATA_leads.indexOf(l)})">⚡ Proposta</button>
        <button class="btn btn-ghost btn-sm" onclick="excluirLead(${DATA_leads.indexOf(l)})">✕</button>
      </div>
    </div>`;
  }).join('');

  // Follow-ups
  const fuDiv = document.getElementById('leads-followups');
  if (fuDiv) {
    const hoje = new Date(); hoje.setHours(0,0,0,0);
    const em7d  = new Date(hoje); em7d.setDate(em7d.getDate() + 7);
    const proxFU = DATA_leads.filter(l => {
      if (!l.followup) return false;
      const d = new Date(l.followup + 'T00:00:00');
      return d >= hoje && d <= em7d;
    }).sort((a,b) => new Date(a.followup) - new Date(b.followup));

    fuDiv.innerHTML = proxFU.length
      ? proxFU.map(l => `<div style="font-size:12px;padding:6px 0;border-bottom:1px solid var(--border);display:flex;justify-content:space-between">
          <span style="font-weight:600">${l.empresa||'—'}</span>
          <span style="color:var(--gold);font-size:11px">${new Date(l.followup+'T00:00:00').toLocaleDateString('pt-BR',{day:'2-digit',month:'short'})}</span>
        </div>`).join('')
      : '<div class="empty-state" style="padding:12px"><div class="empty-sub">Nenhum follow-up nos próximos 7 dias</div></div>';
  }
}

function filterLeads(q = '') {
  renderLeads(typeof q === 'string' ? q : '');
}

async function salvarLead() {
  const empresa  = document.getElementById('lead-empresa')?.value  || '';
  const temp     = document.getElementById('lead-temp')?.value     || 'morno';
  const contato  = document.getElementById('lead-contato')?.value  || '';
  const fone     = document.getElementById('lead-fone')?.value     || '';
  const servico  = document.getElementById('lead-servico')?.value  || '';
  const canal    = document.getElementById('lead-canal')?.value    || '';
  const followup = document.getElementById('lead-followup')?.value || '';
  const valor    = parseFloat(document.getElementById('lead-valor')?.value || '0') || 0;
  const obs      = document.getElementById('lead-obs')?.value      || '';

  if (!empresa) { toast('Informe o nome da empresa', 'warning'); return; }

  const lead = { empresa, temp, contato, fone, servico, canal, followup, valor, obs, data: new Date().toLocaleDateString('pt-BR') };
  DATA_leads.push(lead);

  if (CONFIG.SHEET_ID && accessToken) {
    try {
      await sheetsAppend('MARKETING', [[lead.data, empresa, canal, '', '', '', '', `Lead:${temp} - ${obs}`]]);
    } catch(e) {}
  }

  toast('Lead salvo!', 'success');
  closeModal('modal-novo-lead');
  renderLeads();
  ['lead-empresa','lead-contato','lead-fone','lead-followup','lead-valor','lead-obs'].forEach(id => {
    const el = document.getElementById(id); if (el) el.value = '';
  });
}

function converterLeadIdx(idx) {
  const lead = DATA_leads[idx];
  if (!lead) return;
  // Pré-preencher Nova Proposta com dados do lead
  const setVal = (id, v) => { const el = document.getElementById(id); if (el) el.value = v; };
  setVal('np-contato', lead.contato || lead.empresa);
  setVal('np-fone',    lead.fone);
  const selServ = document.getElementById('np-servico');
  if (selServ) [...selServ.options].forEach(o => { o.selected = o.value === lead.servico; });
  const selCanal = document.getElementById('np-canal');
  if (selCanal) [...selCanal.options].forEach(o => { o.selected = o.value === lead.canal; });
  nav('nova-proposta-page');
  toast(`Lead "${lead.empresa}" carregado na Nova Proposta`, 'info');
}

function converterLeadProposta() {
  const empresa  = document.getElementById('lead-empresa')?.value  || '';
  const contato  = document.getElementById('lead-contato')?.value  || '';
  const fone     = document.getElementById('lead-fone')?.value     || '';
  const servico  = document.getElementById('lead-servico')?.value  || '';
  const canal    = document.getElementById('lead-canal')?.value    || '';

  closeModal('modal-novo-lead');
  const setVal = (id, v) => { const el = document.getElementById(id); if (el) el.value = v; };
  setVal('np-contato', contato || empresa);
  setVal('np-fone',    fone);
  const selServ = document.getElementById('np-servico');
  if (selServ) [...selServ.options].forEach(o => { o.selected = o.value === servico; });
  const selCanal = document.getElementById('np-canal');
  if (selCanal) [...selCanal.options].forEach(o => { o.selected = o.value === canal; });
  nav('nova-proposta-page');
  toast(`Convertendo lead "${empresa}" em proposta`, 'info');
}

function excluirLead(idx) {
  DATA_leads.splice(idx, 1);
  renderLeads();
  toast('Lead removido', 'info');
}

/* ═══════════════════════════════════════════
   FASE 6 — CADASTRO DA EMPRESA
═══════════════════════════════════════════ */
function cadAtualizar() {
  const get = id => document.getElementById(id)?.value || '';

  // Preview cabeçalho
  const fantasia = get('cad-fantasia') || 'Aplica Engenharia';
  const razao    = get('cad-razao')    || 'GEAD APLICA ENGENHARIA LTDA';
  const cnpj     = get('cad-cnpj')     || '—';
  const cidade   = get('cad-cidade')   || '';
  const uf       = get('cad-uf')       || '';
  const tel      = get('cad-tel')      || '—';
  const email    = get('cad-email')    || '—';
  const crea     = get('cad-crea')     || '—';

  const s = id => document.getElementById(id);
  if (s('cprev-fantasia')) s('cprev-fantasia').textContent = fantasia;
  if (s('cprev-razao'))    s('cprev-razao').textContent    = razao;
  if (s('cprev-detalhe'))  s('cprev-detalhe').innerHTML    =
    `CNPJ: ${cnpj}<br>${cidade}${uf?' / '+uf:''}<br>${tel} · ${email}<br>${crea}`;

  // Parâmetros
  const vh    = parseFloat(get('cad-vh')   || '200') || 200;
  const art   = parseFloat(get('cad-art')  || '1000') || 1000;
  const rkm   = parseFloat(get('cad-rkm')  || '0.8') || 0.8;
  const aliq  = parseFloat(get('cad-aliquota') || '6') || 6;
  const meta  = parseFloat(get('cad-meta') || '20000') || 20000;

  if (s('cprev-vh'))   s('cprev-vh').textContent   = fmtMoney(vh);
  if (s('cprev-art'))  s('cprev-art').textContent  = fmtMoney(art);
  if (s('cprev-rkm'))  s('cprev-rkm').textContent  = 'R$ ' + rkm.toFixed(2).replace('.',',');
  if (s('cprev-aliq')) s('cprev-aliq').textContent = aliq + '%';
  if (s('cprev-meta')) s('cprev-meta').textContent = fmtMoney(meta);
}

function salvarCadastro() {
  const get = id => document.getElementById(id)?.value || '';

  const cadastro = {
    razao:     get('cad-razao'),
    fantasia:  get('cad-fantasia'),
    cnpj:      get('cad-cnpj'),
    ie:        get('cad-ie'),
    regime:    get('cad-regime'),
    aliquota:  get('cad-aliquota'),
    end:       get('cad-end'),
    cidade:    get('cad-cidade'),
    uf:        get('cad-uf'),
    cep:       get('cad-cep'),
    resp:      get('cad-resp'),
    crea:      get('cad-crea'),
    tel:       get('cad-tel'),
    email:     get('cad-email'),
    site:      get('cad-site'),
    instagram: get('cad-instagram'),
    vh:        get('cad-vh'),
    art:       get('cad-art'),
    rkm:       get('cad-rkm'),
    val_dias:  get('cad-val-dias'),
    meta:      get('cad-meta'),
    desc_max:  get('cad-desc-max'),
    cond_pagto:get('cad-cond-pagto'),
    rodape:    get('cad-rodape'),
  };

  // Persistir no localStorage
  localStorage.setItem('cad_empresa', JSON.stringify(cadastro));

  // Propagar para calculadora e preview
  const setEl = (id, v) => { const el = document.getElementById(id); if (el && v) el.value = v; };
  setEl('calc-vh',    cadastro.vh);
  setEl('calc-art',   cadastro.art);
  setEl('calc-rkm',   cadastro.rkm);
  setEl('calc-imp',   cadastro.aliquota);
  setEl('prev-crea',  cadastro.crea);
  setEl('prev-resp',  cadastro.resp ? cadastro.resp + ' — Engenheiro Eletricista' : '');
  setEl('prev-tel',   cadastro.tel);
  setEl('prev-email-emp', cadastro.email);
  setEl('prev-cidade', cadastro.cidade + (cadastro.uf ? ' / ' + cadastro.uf : ''));
  setEl('prev-val-dias', cadastro.val_dias);
  setEl('prev-obs-prop', cadastro.rodape);

  // Salvar no Sheets aba CADASTRO (opcional)
  if (CONFIG.SHEET_ID && accessToken) {
    sheetsAppend('CADASTRO', [Object.values(cadastro)])
      .then(() => toast('✅ Cadastro salvo no Sheets!', 'success'))
      .catch(() => toast('Cadastro salvo localmente (Sheets indisponível)', 'warning'));
  } else {
    toast('✅ Cadastro salvo! Parâmetros atualizados em todo o sistema.', 'success');
  }

  cadAtualizar();
}

function loadCadastroFromStorage() {
  try {
    const saved = localStorage.getItem('cad_empresa');
    if (!saved) return;
    const cadastro = JSON.parse(saved);
    const setEl = (id, v) => { const el = document.getElementById(id); if (el && v !== undefined) el.value = v; };
    Object.entries({
      'cad-razao': cadastro.razao, 'cad-fantasia': cadastro.fantasia,
      'cad-cnpj': cadastro.cnpj, 'cad-ie': cadastro.ie,
      'cad-end': cadastro.end, 'cad-cidade': cadastro.cidade,
      'cad-uf': cadastro.uf, 'cad-cep': cadastro.cep,
      'cad-resp': cadastro.resp, 'cad-crea': cadastro.crea,
      'cad-tel': cadastro.tel, 'cad-email': cadastro.email,
      'cad-site': cadastro.site, 'cad-instagram': cadastro.instagram,
      'cad-vh': cadastro.vh, 'cad-art': cadastro.art,
      'cad-rkm': cadastro.rkm, 'cad-val-dias': cadastro.val_dias,
      'cad-meta': cadastro.meta, 'cad-desc-max': cadastro.desc_max,
      'cad-aliquota': cadastro.aliquota,
      'cad-cond-pagto': cadastro.cond_pagto, 'cad-rodape': cadastro.rodape,
    }).forEach(([id, v]) => setEl(id, v));

    // Propagar parâmetros
    if (cadastro.vh)       { setEl('calc-vh', cadastro.vh); }
    if (cadastro.art)      { setEl('calc-art', cadastro.art); }
    if (cadastro.aliquota) { setEl('calc-imp', cadastro.aliquota); }
  } catch(e) {}
}

// Adicionar listeners de input ao cadastro
document.addEventListener('DOMContentLoaded', () => {
  ['cad-razao','cad-fantasia','cad-cnpj','cad-cidade','cad-uf','cad-resp','cad-crea','cad-tel',
   'cad-email','cad-vh','cad-art','cad-rkm','cad-aliquota','cad-meta'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.addEventListener('input', cadAtualizar);
  });
  loadCadastroFromStorage();
  cadAtualizar();
});

