/* ═══════════════════════════════════════════
   GOOGLE CALENDAR
═══════════════════════════════════════════ */
async function loadCalendar() {
  const container = document.getElementById('calendar-events');

  if (!accessToken) {
    container.innerHTML = `<div class="empty-state"><div class="empty-icon">🔒</div><div class="empty-title">Login necessário</div><div class="empty-sub">Faça login para ver sua agenda do Google Calendar.</div></div>`;
    return;
  }

  container.innerHTML = `<div class="empty-state"><div class="empty-icon" style="animation:pulse 1s infinite">📅</div><div class="empty-sub">Carregando eventos...</div></div>`;

  try {
    const now    = new Date().toISOString();
    const future = new Date(Date.now() + 30*24*60*60*1000).toISOString();
    const calId  = encodeURIComponent(CONFIG.CALENDAR_ID);

    const resp = await fetch(
      `https://www.googleapis.com/calendar/v3/calendars/${calId}/events?timeMin=${now}&timeMax=${future}&orderBy=startTime&singleEvents=true&maxResults=15`,
      { headers: { Authorization: 'Bearer ' + accessToken } }
    );

    if (!resp.ok) throw new Error('Calendar API: ' + resp.status);
    const data = await resp.json();
    const events = data.items || [];

    // Atualizar badge
    const hojeFim = new Date(); hojeFim.setHours(23,59,59);
    const hoje7   = new Date(); hoje7.setDate(hoje7.getDate() + 7);
    const proximos = events.filter(e => {
      const start = new Date(e.start?.dateTime || e.start?.date);
      return start <= hoje7;
    }).length;
    const badge = document.getElementById('badge-agenda');
    if (badge) { badge.textContent = proximos; badge.style.display = proximos ? 'inline' : 'none'; }

    if (!events.length) {
      container.innerHTML = `<div class="empty-state"><div class="empty-icon">✅</div><div class="empty-title">Agenda limpa</div><div class="empty-sub">Nenhum evento nos próximos 30 dias.</div></div>`;
      return;
    }

    const hoje = new Date(); hoje.setHours(0,0,0,0);

    container.innerHTML = `<div class="calendar-events">${events.map(e => {
      const start   = new Date(e.start?.dateTime || e.start?.date);
      const isToday = start.toDateString() === hoje.toDateString();
      const isPast  = start < new Date();
      const cls     = isPast ? 'done' : isToday ? 'urgent' : '';

      const dt = e.start?.dateTime
        ? start.toLocaleDateString('pt-BR', {day:'2-digit',month:'short'}) + ' às ' + start.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})
        : start.toLocaleDateString('pt-BR', {day:'2-digit',month:'short',year:'numeric'});

      return `<div class="cal-event ${cls}">
        <div class="cal-time">${dt}</div>
        <div>
          <div class="cal-title">${e.summary || 'Sem título'}</div>
          ${e.location ? `<div class="cal-sub">📍 ${e.location}</div>` : ''}
          ${e.description ? `<div class="cal-sub">${e.description.slice(0,80)}${e.description.length>80?'…':''}</div>` : ''}
        </div>
      </div>`;
    }).join('')}</div>`;

  } catch(e) {
    container.innerHTML = `<div class="empty-state"><div class="empty-icon">⚠️</div><div class="empty-title">Erro ao carregar</div><div class="empty-sub">${e.message}</div></div>`;
    toast('Erro no Calendar: ' + e.message, 'error');
  }
}

async function createCalendarEvent() {
  const title = document.getElementById('ev-title')?.value || '';
  const date  = document.getElementById('ev-date')?.value  || '';
  const time  = document.getElementById('ev-time')?.value  || '09:00';
  const desc  = document.getElementById('ev-desc')?.value  || '';

  if (!title || !date) { toast('Preencha título e data', 'warning'); return; }

  if (!accessToken) { toast('Faça login primeiro', 'warning'); return; }

  try {
    const start = new Date(`${date}T${time}:00`);
    const end   = new Date(start.getTime() + 60*60*1000); // 1h

    const calId = encodeURIComponent(CONFIG.CALENDAR_ID);
    const resp  = await fetch(`https://www.googleapis.com/calendar/v3/calendars/${calId}/events`, {
      method: 'POST',
      headers: { Authorization: 'Bearer ' + accessToken, 'Content-Type': 'application/json' },
      body: JSON.stringify({
        summary:     title,
        description: desc,
        start: { dateTime: start.toISOString(), timeZone: 'America/Sao_Paulo' },
        end:   { dateTime: end.toISOString(),   timeZone: 'America/Sao_Paulo' },
      })
    });

    if (!resp.ok) { const err = await resp.json(); throw new Error(err.error?.message || 'Erro'); }

    toast('✅ Evento criado no Google Calendar!', 'success');
    document.getElementById('ev-title').value = '';
    document.getElementById('ev-date').value  = '';
    document.getElementById('ev-desc').value  = '';
    loadCalendar();
  } catch(e) {
    toast('Erro ao criar evento: ' + e.message, 'error');
  }
}

