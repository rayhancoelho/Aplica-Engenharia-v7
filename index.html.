function filterCRM() {
  const q       = (document.getElementById('crm-search')?.value || '').toLowerCase();
  const status  = document.getElementById('crm-filter-status')?.value || '';
  const servico = document.getElementById('crm-filter-servico')?.value || '';

  const filtered = DATA.crm.filter(r => {
    const matchQ   = !q || [r[CRM_COL.ID],r[CRM_COL.CNPJ],r[CRM_COL.RAZAO],r[CRM_COL.SERVICO],r[CRM_COL.STATUS]].some(v => (v||'').toLowerCase().includes(q));
    const matchSt  = !status  || (r[CRM_COL.STATUS]||'') === status;
    const matchSv  = !servico || (r[CRM_COL.SERVICO]||'').toUpperCase().includes(servico.split(' ')[0]);
    return matchQ && matchSt && matchSv;
  });

  renderCRMRows(filtered);
}

