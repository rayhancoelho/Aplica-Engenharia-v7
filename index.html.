async function salvarRevisao() {
  const idProp  = document.getElementById('rev-id-prop')?.value || '';
  const cliente = document.getElementById('rev-cliente')?.value || '';
  const num     = document.getElementById('rev-num')?.value     || '';
  const status  = document.getElementById('rev-status')?.value  || 'Pendente';
  const valAnt  = parseFloat(document.getElementById('rev-val-ant')?.value  || '0') || 0;
  const valNovo = parseFloat(document.getElementById('rev-val-novo')?.value || '0') || 0;
  const motivo  = document.getElementById('rev-motivo')?.value  || '';

  if (!idProp) { toast('Informe o ID da proposta', 'warning'); return; }

  const rev = {
    proposta: idProp,
    cliente,
    num:      num || 'REV-' + String(DATA_revisoes.length + 1).padStart(3,'0'),
    status,
    val_ant:  valAnt,
    val_novo: valNovo,
    motivo,
    data:     new Date().toLocaleDateString('pt-BR'),
  };

  DATA_revisoes.push(rev);

  // Salvar no Sheets aba HISTORICO_PROPOSTAS
  if (CONFIG.SHEET_ID && accessToken) {
    try {
      const row = [rev.data, rev.proposta, rev.cliente, rev.num, rev.status, rev.val_ant, rev.val_novo, rev.motivo];
      await sheetsAppend('HISTORICO_PROPOSTAS', [row]);
      toast('✅ Revisão salva no Sheets!', 'success');
