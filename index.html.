async function _fetchCNPJData(cnpj, fields, previewId) {
  try {
    // Tentar API BrasilAPI (sem CORS issues)
    const resp = await fetch(`https://brasilapi.com.br/api/cnpj/v1/${cnpj}`);
    if (!resp.ok) throw new Error('CNPJ não encontrado');

    const d = await resp.json();

    if (fields.razao    && document.getElementById(fields.razao))    document.getElementById(fields.razao).value    = d.razao_social        || '';
    if (fields.fantasia && document.getElementById(fields.fantasia)) document.getElementById(fields.fantasia).value = d.nome_fantasia       || d.razao_social || '';
    if (fields.endereco && document.getElementById(fields.endereco)) document.getElementById(fields.endereco).value = `${d.logradouro||''}, ${d.numero||''}${d.complemento?' — '+d.complemento:''}`.trim();
    if (fields.municipio && document.getElementById(fields.municipio)) document.getElementById(fields.municipio).value = `${d.municipio||''} / ${d.uf||''}`;

    if (previewId) {
      const ativo = d.descricao_situacao_cadastral === 'ATIVA';
      document.getElementById(previewId).innerHTML = `
        <div style="display:flex;flex-direction:column;gap:8px;font-size:13px">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px">
            <span class="badge ${ativo ? 'badge-green':'badge-coral'}">${d.descricao_situacao_cadastral||'—'}</span>
            <span class="text-dim" style="font-size:11px">CNPJ ${cnpj.replace(/(\d{2})(\d{3})(\d{3})(\d{4})(\d{2})/,'$1.$2.$3/$4-$5')}</span>
          </div>
          <div><span class="text-dim">Razão Social</span><div class="fw-bold">${d.razao_social||'—'}</div></div>
          <div><span class="text-dim">Nome Fantasia</span><div>${d.nome_fantasia||'—'}</div></div>
          <div><span class="text-dim">Endereço</span><div>${d.logradouro||''}, ${d.numero||''} — ${d.municipio||''}/${d.uf||''}</div></div>
          <div><span class="text-dim">Abertura</span><div>${d.data_inicio_atividade||'—'}</div></div>
          <div><span class="text-dim">Atividade Principal</span><div class="text-muted">${d.cnae_fiscal_descricao||'—'}</div></div>
        </div>`;
    }

    toast('CNPJ encontrado: ' + (d.razao_social||'').slice(0,40), 'success');
  } catch(e) {
    toast('CNPJ não localizado na Receita Federal', 'error');
    if (previewId) {
      document.getElementById(previewId).innerHTML = `<div class="empty-state"><div class="empty-icon">⚠️</div><div class="empty-title">CNPJ não encontrado</div><div class="empty-sub">${e.message}</div></div>`;
    }
  }
}

